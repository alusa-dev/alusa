{
  "name": "@alusa/site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "clean": "rm -rf .next",
    "dev": "next dev -p 3001",
    "dev:clean": "pnpm run clean && next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint src next.config.mjs tailwind.config.js postcss.config.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^2.0.0",
    "next": "15.5.18",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "18.2.74",
    "@types/react-dom": "18.2.22",
    "autoprefixer": "10.4.19",
    "eslint": "^9.39.1",
    "postcss": "8.4.41",
    "tailwindcss": "3.4.10",
    "typescript": "5.6.3"
  }
}
