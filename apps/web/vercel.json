{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["gru1"],
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && find packages -name '*.tsbuildinfo' -delete && pnpm prisma:generate && pnpm exec turbo run build --filter=@alusa/web --force",
  "crons": [
    {
      "path": "/api/jobs/webhook-scheduler?drainLimit=200&skipArchive=true&skipHealthCheck=true&skipDriftCheck=true",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/jobs/provision-asaas-subaccounts",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/jobs/reconcile-finance-webhooks?includeGaps=true&windowHours=24&limit=100&maxAccounts=20",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/jobs/events-expire-reservations?limit=200&maxAccounts=20",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/jobs/events-reconcile-orders?olderThanMinutes=10&limit=100&maxAccounts=20",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/jobs/events-inspect-financial-inconsistencies?limit=200&maxAccounts=20",
      "schedule": "20 * * * *"
    },
    {
      "path": "/api/jobs/webhook-maintenance",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/jobs/reconcile-finance-accounts",
      "schedule": "15 */2 * * *"
    },
    {
      "path": "/api/jobs/auto-close-agenda-events",
      "schedule": "*/15 * * * *"
    }
  ]
}
