# Configuração do banco PostgreSQL para o MCP alusadb

# Opção 1: URL de conexão completa (recomendado)
DATABASE_URL=

# Opção 2: Variáveis separadas (alternativa)
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=alusa_dev
# PGUSER=usuario
# PGPASSWORD=senha

# Opcional: schemas permitidos (vírgula separados)
# Se não definido, todos os schemas são permitidos
# ALLOWED_SCHEMAS=public,app
