{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
  "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
  "verbatimModuleSyntax": true,
  "ignoreDeprecations": "5.0",
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": ["node"],
    "paths": {
      "@alusa/ui": ["./packages/ui/src"],
      "@alusa/ui/*": ["./packages/ui/src/*"],
      "@alusa/asaas": ["./packages/asaas/src"],
      "@alusa/asaas/*": ["./packages/asaas/src/*"],
      "@alusa/asaas-gateway": ["./packages/asaas-gateway/src"],
      "@alusa/asaas-gateway/*": ["./packages/asaas-gateway/src/*"],
      "@alusa/shared": ["./packages/shared/src"],
      "@alusa/shared/*": ["./packages/shared/src/*"],
      "@alusa/database": ["./packages/database/src"],
      "@alusa/database/*": ["./packages/database/src/*"],
      "@alusa/domain": ["./packages/domain/src"],
      "@alusa/domain/*": ["./packages/domain/src/*"],
      "@alusa/finance": ["./packages/finance/src"],
      "@alusa/finance/*": ["./packages/finance/src/*"],
      "@alusa/lib": ["./packages/lib/src"],
      "@alusa/lib/*": ["./packages/lib/src/*"],
      "@alusa/config/*": ["./packages/config/*"],
      "@/*": ["./apps/web/*"]
    }
  }
}
