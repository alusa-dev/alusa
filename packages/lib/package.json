{
  "name": "@alusa/lib",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./cpf-cnpj": {
      "types": "./dist/utils/cpf-cnpj.d.ts",
      "default": "./dist/utils/cpf-cnpj.js"
    },
    "./date-only": {
      "types": "./dist/utils/date-only.d.ts",
      "default": "./dist/utils/date-only.js"
    },
    "./errors/asaas-customer-ensure-error": {
      "types": "./dist/errors/asaas-customer-ensure-error.d.ts",
      "default": "./dist/errors/asaas-customer-ensure-error.js"
    },
    "./prisma": {
      "types": "./dist/prisma.d.ts",
      "default": "./dist/prisma.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run"
  },
  "dependencies": {
    "@alusa/asaas": "workspace:*",
    "@alusa/domain": "workspace:*",
    "@alusa/shared": "workspace:*",
    "@aws-sdk/client-s3": "^3.1040.0",
    "axios": "^1.12.2",
    "jose": "^4.15.9",
    "twilio": "^4.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/react": "18.2.74",
    "react": "18.2.0",
    "typescript": "5.6.3",
    "vitest": "^4.0.18"
  }
}
