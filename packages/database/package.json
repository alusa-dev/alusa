{
  "name": "@alusa/database",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -w -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "@alusa/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.5.1",
    "prisma": "^5.18.0",
    "typescript": "^5.6.3",
    "vitest": "^2.0.5"
  }
}
