{
  "name": "@alusa/asaas-gateway",
  "version": "0.0.1",
  "private": true,
  "description": "Gateway centralizado para integração Asaas (billing v2)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@alusa/asaas": "workspace:*",
    "@alusa/database": "workspace:*",
    "@alusa/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
