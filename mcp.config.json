{
  "mcpServers": {
    "alusadb": {
      "command": "npx",
      "args": [
        "dotenv",
        "-e",
        ".env",
        "--",
        "tsx",
        "mcp/alusadb/src/index.ts"
      ],
      "cwd": "${workspaceFolder}"
    },
    "asaas": {
      "url": "https://docs.asaas.com/mcp"
    },
    "tiptap": {
      "command": "npx",
      "args": [
        "dotenv",
        "-e",
        ".env",
        "--",
        "tsx",
        "mcp/tiptap/server.ts"
      ],
      "cwd": "${workspaceFolder}"
    },
    "prosemirror": {
      "command": "npx",
      "args": [
        "dotenv",
        "-e",
        ".env",
        "--",
        "tsx",
        "mcp/prosemirror/server.ts"
      ],
      "cwd": "${workspaceFolder}"
    },
    "cloudflare-api": {
      "url": "https://mcp.cloudflare.com/mcp"
    },
    "vercel-api": {
      "url": "https://mcp.vercel.com"
    },
    "hostinger-api": {
      "command": "npx",
      "args": [
        "dotenv",
        "-e",
        ".env",
        "--",
        "hostinger-api-mcp"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "DEBUG": "false"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "dotenv",
        "-e",
        ".env.local",
        "--",
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "cwd": "${workspaceFolder}"
    }
  }
}
