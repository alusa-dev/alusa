{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["gru1"],
  "crons": [
    {
      "path": "/api/jobs/process-finance-webhooks",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/jobs/provision-asaas-subaccounts",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/jobs/asaas-health-check",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/jobs/reconcile-finance-accounts",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/jobs/reconcile-finance-webhooks?includeGaps=true&windowHours=24&limit=100&maxAccounts=20",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/jobs/webhook-maintenance",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/jobs/process-pending-inbox-notifications",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/jobs/process-overdue-billing-notifications",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/jobs/notify-contracts-expiring",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/jobs/encerrar-contratos",
      "schedule": "30 4 * * *"
    }
  ]
}
