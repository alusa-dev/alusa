  @@index([contaId, groupId], name: "idx_charge_read_model_conta_group")
  @@index([contaId, matriculaId], name: "idx_charge_read_model_conta_matricula")
  @@index([contaId, alunoId], name: "idx_charge_read_model_conta_aluno")
  @@index([contaId, linkStatus], name: "idx_charge_read_model_conta_link_status")
  @@index([contaId, projectedAt], name: "idx_charge_read_model_conta_projected")
  @@index([asaasPaymentId], name: "idx_charge_read_model_asaas_payment")
}

