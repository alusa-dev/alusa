enum SaleStatus {
  CONCLUIDA
  PENDENTE
  VINCULADA_MENSALIDADE
  CANCELADA
}

enum SaleFinalizationType {
  RECEBIMENTO_PRESENCIAL
  COBRANCA
  MENSALIDADE
}

enum SalePaymentMethod {
  DINHEIRO
  PIX_PRESENCIAL
  CARTAO_DEBITO
  CARTAO_CREDITO
}

enum SaleInventoryMode {
  IMMEDIATE
  RESERVE
}

enum SaleInventoryStatus {
  FULFILLED
  RESERVED
  CANCELED
  RETURNED_PARTIAL
  RETURNED_TOTAL
}

enum InventoryMovementType {
  OPENING_IN
  ENTRY_IN
  RESTOCK_IN
  SALE_OUT
  RESERVE
  RELEASE
  RETURN_IN
  ADJUST_IN
  ADJUST_OUT
  LOSS_OUT
}

enum RestockOrderStatus {
  PLANEJADO
  RECEBIDO_PARCIAL
  RECEBIDO
  CANCELADO
}

