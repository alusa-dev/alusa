// Prisma schema inicial

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Models de autentica��o

enum Status {
  ATIVO
  INATIVO
}

enum AuthActionTokenType {
  VERIFY_EMAIL
  RESET_PASSWORD
}

// Formas de pagamento compatíveis com Asaas billingType
// Referência: https://docs.asaas.com/reference/criar-nova-cobranca
// Apenas 4 tipos suportados pelo Asaas em pagamentos básicos
enum FormaPagamento {
  BOLETO // Sincronizado com BOLETO do Asaas - "Boleto Bancário / Pix"
  PIX // Sincronizado com PIX do Asaas - "Pix"
  CARTAO_CREDITO // Sincronizado com CREDIT_CARD do Asaas - "Cartão de Crédito"
  INDEFINIDO // Sincronizado com UNDEFINED do Asaas - "Pergunte ao cliente"
}

// Lancamentos financeiros (Receita/Despesa)
enum TipoLancamento {
  RECEITA
  DESPESA
}

enum OrigemLancamento {
  SISTEMA
  MANUAL
}

enum StatusLancamento {
  RECEBIDO
  PREVISTO
  PAGO
  PENDENTE
  ESTORNADO
}

enum FormaPagamentoLancamento {
  PIX
  BOLETO
  CARTAO_CREDITO
  CARTAO_DEBITO
  DINHEIRO
  TRANSFERENCIA
  TED
  DOC
  DEBITO_AUTOMATICO
  CHEQUE
  VOUCHER
  OUTRO
}

enum CentroCustoTipo {
  RECEITA
  DESPESA
  MISTO
}

enum StatusMatricula {
  PENDENTE_TAXA
  AGUARDANDO_CONFIRMACAO
  ATIVA
  PAUSADA
  RECUSADA
  CANCELADA
}

enum CalendarEventType {
  AULA
  REPOSICAO
  EVENTO_INTERNO
  EVENTO_EXTERNO
  WORKSHOP
  FERIADO
  PAUSA
  CANCELAMENTO
  SUBSTITUICAO
}

enum CalendarEventStatus {
  AGENDADO
  CANCELADO
  REALIZADO
}

enum AttendanceStatus {
  PRESENTE
  FALTA
  FALTA_JUSTIFICADA
  ATRASO
  REPOSICAO
}

enum MakeupClassStatus {
  AGENDADA
  REALIZADA
  CANCELADA
}

enum MakeupClassScope {
  INDIVIDUAL
  COLETIVA
}

enum AulasOperationLogLevel {
  INFO
  WARNING
  ERROR
}

// Política de ativação de matrícula por conta/instituição
enum MatriculaActivationPolicy {
  IMMEDIATE // Matrícula é ativada imediatamente ao ser criada
  REQUIRES_PAYMENT // Matrícula aguarda pagamento da taxa para ativar
}

enum RematriculaDebtPolicy {
  PERMITIR_NORMALMENTE
  PERMITIR_COM_AVISO
  PERMITIR_COM_AUTORIZACAO_ADMINISTRATIVA
  BLOQUEAR_REMATRICULA
}

enum RematriculaDebtScope {
  QUALQUER_COBRANCA_EM_ABERTO
  SOMENTE_ATRASADAS
}

enum RematriculaActionStatus {
  LIBERADA
  LIBERADA_COM_AVISO
  REQUER_OVERRIDE
  BLOQUEADA
}

enum RematriculaBlockReason {
  SEM_BLOQUEIO
  COBRANCA_EM_ABERTO
  COBRANCA_ATRASADA
  MULTIPLAS_COBRANCAS
  AGUARDANDO_RECONCILIACAO
  POLITICA_DA_ESCOLA
  OUTRO
}

enum StatusTaxaMatricula {
  PENDENTE
  PAGO
  EXPIRADO
  ISENTO
}

enum TipoCobranca {
  TAXA_MATRICULA
  MENSALIDADE
  EXTRA
  AVULSA // Sincronizado com DETACHED do Asaas
  PARCELADA // Sincronizado com INSTALLMENT do Asaas
  RECORRENTE // Sincronizado com RECURRENT do Asaas
}

enum StatusCobranca {
  A_VENCER // Cobrança criada, vencimento futuro
  PENDENTE // Vencimento chegou, aguardando pagamento
  PROCESSANDO // Pagamento em análise/processamento
  PAGO // Pagamento confirmado
  ATRASADO // Vencimento passou, sem pagamento
  CANCELAMENTO_PENDENTE // Aguardando confirmação de cancelamento no Asaas
  CANCELADO // Cobrança cancelada
  ESTORNADO // Pagamento estornado/reembolsado
  ESTORNADO_PARCIAL // Estorno parcial do pagamento
}

// Status de liquidação (saldo disponível) - separado do status de cobrança
// Permite rastrear quando o valor está efetivamente disponível na conta
enum LiquidacaoStatus {
  NAO_APLICAVEL // Cobrança não paga ou cancelada
  PENDENTE // Pagamento confirmado, saldo ainda não disponível
  DISPONIVEL // Saldo creditado na conta
}

enum StatusFinanceiro {
  ADIMPLENTE
  PENDENTE_TAXA
  PENDENTE_FINANCEIRO // Estado intermediário: aguardando confirmação de operação financeira
  INADIMPLENTE
  SUSPENSO // Matrículas com cobranças suspensas temporariamente
}

enum StatusContrato {
  AGUARDANDO_ASSINATURA
  ATIVO
  EXPIRADO
  CANCELADO
}

enum StatusAssinatura {
  PENDENTE // Aguardando assinatura
  ASSINADO // Contrato assinado
  EXPIRADO // Link de assinatura expirou
  CANCELADO // Assinatura cancelada
}

// ==================== Finance (Whitelabel) ====================

enum CustomerPayerType {
  ALUNO
  RESPONSAVEL
}

// Modo de cobrança da matrícula
// INDIVIDUAL: cobrança direta do aluno/responsável
// SHARED_PLAN: compartilha plano com irmãos (desconto família)
enum BillingMode {
  INDIVIDUAL
  SHARED_PLAN
}

// Status de sincronização com integração financeira
enum IntegrationSyncStatus {
  PENDENTE_SINCRONISMO
  SINCRONIZADO
  DIVERGENTE
}

// Tipo de operação de matrícula
enum TipoOperacaoMatricula {
  PAUSA
  REATIVACAO
  CANCELAMENTO
  RECONCILIACAO
}

// Origem da operação
enum OrigemOperacao {
  USER
  WEBHOOK
  JOB
}

// Status de uma operação
enum StatusOperacao {
  PENDENTE_SINCRONISMO
  SINCRONIZADO
  ERRO
  DIVERGENTE
}

// Status de operação de troca de pagador
enum PayerChangeOperacaoStatus {
  PENDING // Operação criada, validações passaram
  OLD_SUB_CANCELLED // Assinatura antiga cancelada
  NEW_SUB_CREATED // Nova assinatura criada
  COMMITTED // Operação concluída com sucesso
  FAILED // Falha recuperável
  ROLLED_BACK // Rollback executado
}

enum RematriculaOperacaoStatus {
  PENDING // Operação criada, validações passaram
  PENDING_FINANCE // Aguardando resposta do gateway
  COMMITTED // Assinatura criada com sucesso, origem cancelada
  DONE // Webhook confirmou pagamento (legado)
  FAILED // Falha recuperável (permite retry)
  CANCELLED // Cancelada manualmente
}

enum RematriculaOperacaoStep {
  VALIDATED // Validações passaram
  NEW_MATRICULA_CREATED // Nova matrícula criada (provisória)
  SUBSCRIPTION_CREATED // Assinatura criada no gateway
  ORIGIN_CANCELLED // Matrícula origem cancelada
  COMPLETED // Fluxo completo
}

enum ChargeStatus {
  CREATED
  PENDING_SYNC
  OPEN
  PAID
  OVERDUE
  CANCELED
  REFUNDED
}

enum AsaasIntegrationJobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum AsaasIntegrationJobType {
  CREATE_PAYMENT
  CREATE_INSTALLMENT
  CREATE_SUBSCRIPTION
}

enum TransferStatus {
  REQUESTED
  PENDING
  BLOCKED
  PROCESSING
  DONE
  CANCELED
  FAILED
}

enum PixTransferSessionStatus {
  WAITING_PREVIEW
  PREVIEW_READY
  PREVIEW_UNAVAILABLE
  WAITING_CONFIRM
  DONE
  FAILED
  EXPIRED
}

enum SubscriptionStatus {
  REQUESTED
  ACTIVE
  INACTIVE
  EXPIRED
  DELETED
  FAILED
}

enum InstallmentStatus {
  ACTIVE
  COMPLETED
  CANCELED
}

enum AsaasNotificationEvent {
  PAYMENT_CREATED
  PAYMENT_UPDATED
  PAYMENT_DUEDATE_WARNING
  SEND_LINHA_DIGITAVEL
  PAYMENT_OVERDUE
  PAYMENT_RECEIVED
}

enum NotificationCategory {
  ENROLLMENT
  BILLING
  PAYMENT
  SYSTEM
}

enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
  CRITICAL
}

enum NotificationType {
  ENROLLMENT_CREATED
  BILLING_CREATED
  BILLING_OVERDUE
  BILLING_CANCELLED
  PAYMENT_CONFIRMED
  PAYMENT_REFUNDED
  SYSTEM_ATTENTION
  TRANSFER_DONE
  TRANSFER_FAILED
  TRANSFER_CANCELLED
  BALANCE_BLOCKED
  ACCESS_TOKEN_ALERT
  WEBHOOK_INTERRUPTED
  WEBHOOK_DLQ
}

enum PeriodicidadePlano {
  SEMANAL
  QUINZENAL
  MENSAL
  TRIMESTRAL
  ANUAL
}

enum Role {
  ADMIN
  FINANCEIRO
  RECEPCAO
  PROFESSOR
  RESPONSAVEL
}

enum Genero {
  MASCULINO
  FEMININO
  NAO_BINARIO
  OUTRO
  PREFERE_NAO_INFORMAR
}

// --- Colaboradores ---

enum CargoColaborador {
  PROFESSOR
  RECEPCAO
  FINANCEIRO
  ADMINISTRATIVO
  OUTRO
}

enum StatusColaborador {
  ATIVO
  INATIVO
}

model Colaborador {
  id      String @id @default(cuid())
  contaId String

  // Identificação
  foto       String?
  nome       String
  nomeSocial String?
  dataNasc   DateTime?
  genero     Genero?

  // Documentos
  cpf          String?
  rg           String?
  orgaoEmissor String?
  dataEmissao  DateTime?

  // Contato
  email                     String?
  telefone1                 String?
  contatoEmergenciaTelefone String?

  // Endereço
  enderecoCep         String? @db.Char(8)
  enderecoLogradouro  String?
  enderecoNumero      String?
  enderecoComplemento String?
  enderecoBairro      String?
  enderecoCidade      String?
  enderecoUf          String? @db.Char(2)

  // Vínculo
  cargo            CargoColaborador
  especialidade    String?
  status           StatusColaborador @default(ATIVO)
  dataAdmissao     DateTime?
  dataDesligamento DateTime?
  observacoes      String?
  salario          Decimal?          @db.Decimal(12, 2)

  // Acesso ao sistema
  temAcesso Boolean  @default(false)
  usuarioId String?  @unique
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conta Conta @relation(fields: [contaId], references: [id], onDelete: Cascade)

  // Unicidade por conta (multi-tenant)
  @@unique([contaId, cpf])
  @@unique([contaId, email])
  @@index([contaId])
}

model Conta {
  id                           String                        @id @default(cuid())
  nome                         String
  cpfCnpj                      String?
  status                       Status                        @default(ATIVO)
  financeStatus                FinanceStatus                 @default(FINANCE_NOT_STARTED)
  deletedAt                    DateTime?
  deletedByUserId              String?
  deletedByUser                Usuario?                      @relation("ContaDeletedBy", fields: [deletedByUserId], references: [id])
  deleteReason                 String?
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  // Dono (owner) da conta — imutável na lógica de negócio
  ownerUserId                  String?
  ownerUser                    Usuario?                      @relation("ContaOwner", fields: [ownerUserId], references: [id])
  usuarios                     Usuario[]                     @relation("ContaUsuarios")
  usuariosConta                UsuarioConta[]
  invites                      Invite[]
  alunos                       Aluno[]
  turmas                       Turma[]
  planos                       Plano[]
  combos                       Combo[]
  descontos                    Desconto[]
  webhooks                     WebhookAsaas[]
  webhooksArchive              WebhookAsaasArchive[]
  logsFinanceiros              LogFinanceiro[]
  logsIntegracao               LogIntegracao[]
  asaasIntegrationJobs         AsaasIntegrationJob[]
  asaasNotificationPreferences AsaasNotificationPreference[]
  // Núcleo financeiro whitelabel (Fases 0+)
  financeProfile               FinanceProfile?
  tenantFeatureFlags           TenantFeatureFlags?
  auditLogs                    AuditLog[]
  notifications                Notification[]
  notificationRecipients       NotificationRecipient[]
  customers                    Customer[]
  charges                      Charge[]
  chargeReadModels             ChargeReadModel[]
  invoices                     Invoice[]
  subscriptions                Subscription[]
  installmentPlans             InstallmentPlan[]
  standaloneInstallmentPlans   StandaloneInstallmentPlan[]
  standaloneSubscriptions      StandaloneSubscription[]
  transferRequests             TransferRequest[]
  pixTransferSessions          PixTransferSession[]
  professores                  Professor[]
  colaboradores                Colaborador[]
  responsaveis                 Responsavel[]
  modalidades                  Modalidade[]
  salas                        Sala[]
  lancamentos                  Lancamento[]
  centrosCusto                 CentroCusto[]
  categoriasLancamento         CategoriaLancamento[]
  portalEventos                PortalEvento[]
  contratoTemplates            ContratoTemplate[]
  contratoModelos              ContratoModelo[]
  rematriculaOperacoes         RematriculaOperacao[]
  payerChangeOperacoes         PayerChangeOperacao[]
  matriculaOperacoes           MatriculaOperacao[]
  calendarEvents               CalendarEvent[]
  attendanceRecords            AttendanceRecord[]
  makeupClasses                MakeupClass[]
  aulasOperationLogs           AulasOperationLog[]
  // Loja / Vendas
  products                     Product[]
  productCategories            ProductCategory[]
  sales                        Sale[]
  inventoryBalances            InventoryBalance[]
  inventoryMovements           InventoryMovement[]
  restockOrders                RestockOrder[]
  // Campos de endereco da conta (escola)
  enderecoCep                  String?                       @db.Char(8)
  enderecoLogradouro           String?
  enderecoNumero               String?
  enderecoBairro               String?
  enderecoCidade               String?
  enderecoUf                   String?                       @db.Char(2)
  // Credenciais de integração (criptografadas em repouso). Armazenamos separadamente para permitir rotação.
  asaasApiKeyEncrypted         String?
  asaasWebhookSecretEncrypted  String?
  asaasCredsUpdatedAt          DateTime?
  // Política de ativação de matrícula
  matriculaActivationPolicy    MatriculaActivationPolicy     @default(IMMEDIATE)
  financialPolicy              ContaFinancialPolicy?

  @@index([cpfCnpj])
  @@index([ownerUserId])
  @@index([deletedAt])
  @@index([deletedByUserId])
}

model ContaFinancialPolicy {
  id                                 String                @id @default(cuid())
  contaId                            String                @unique
  rematriculaDebtPolicy              RematriculaDebtPolicy @default(PERMITIR_NORMALMENTE)
  allowNewFinancialCycleWithOpenDebt Boolean               @default(true)
  debtScope                          RematriculaDebtScope  @default(QUALQUER_COBRANCA_EM_ABERTO)
  overrideRoles                      String[]              @default(["ADMIN", "FINANCEIRO"])
  requireOverrideReason              Boolean               @default(true)
  requireFullAudit                   Boolean               @default(true)
  blockOnUnknownFinancialStatus      Boolean               @default(true)
  createdAt                          DateTime              @default(now())
  updatedAt                          DateTime              @updatedAt

  conta Conta @relation(fields: [contaId], references: [id], onDelete: Cascade)

  @@index([contaId])
}

model AsaasNotificationPreference {
  id                              String                 @id @default(cuid())
  contaId                         String
  event                           AsaasNotificationEvent
  scheduleOffset                  Int                    @default(0)
  enabled                         Boolean                @default(true)
  emailEnabledForProvider         Boolean                @default(false)
  smsEnabledForProvider           Boolean                @default(false)
  emailEnabledForCustomer         Boolean                @default(true)
  smsEnabledForCustomer           Boolean                @default(true)
  whatsappEnabledForCustomer      Boolean                @default(false)
  phoneCallEnabledForCustomer     Boolean                @default(false)
  whatsappCapabilitySupported     Boolean                @default(true)
  whatsappCapabilityLastCheckedAt DateTime?
  whatsappCapabilityLastErrorCode String?
  whatsappCapabilityEnvironment   String?
  createdAt                       DateTime               @default(now())
  updatedAt                       DateTime               @updatedAt

  conta Conta @relation(fields: [contaId], references: [id], onDelete: Cascade)

  @@unique([contaId, event, scheduleOffset])
  @@index([contaId])
}

/// Modelo de Professor com foco em multi-tenant via contaId.
/// Decisões:
/// - status como String com default "ATIVO" (evita acoplamento a enum para flexibilidade futura).
/// - email opcional porém único globalmente (Postgres permite vários NULLs em índice único).
/// - nome terá validação de tamanho mínimo (>= 2) aplicada na camada de aplicação (Zod), não no schema.
/// - Relação futura com TurmaProfessor (campo `turmas`) ficará comentada até o modelo existir.
enum StatusContratual {
  EFETIVO
  TEMPORARIO
  PRESTADOR
  VOLUNTARIO
}

model Professor {
  id      String @id @default(cuid())
  contaId String

  // Dados pessoais
  nome          String
  cpf           String?
  rg            String?
  dataNasc      DateTime
  sexo          String?
  estadoCivil   String?
  nacionalidade String?

  // Contato
  email        String?
  telefoneCel  String
  telefoneFixo String?

  // Endereço
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  uf          String? @db.Char(2)

  // Profissional
  formacao         String?
  especialidades   String[]          @default([])
  dataAdmissao     DateTime?
  statusContratual StatusContratual?
  cargaHoraria     Int?
  miniBio          String?
  foto             String?

  status    Status   @default(ATIVO)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conta                    Conta                    @relation(fields: [contaId], references: [id], onDelete: Cascade)
  turmas                   TurmaProfessor[]
  calendarEventProfessores CalendarEventProfessor[]

  // Multi-tenant: unicidade por conta
  @@unique([contaId, cpf])
  @@unique([contaId, email])
  @@index([contaId], name: "idx_professor_conta")
}

model Usuario {
  id                   String    @id @default(cuid())
  contaId              String
  conta                Conta     @relation("ContaUsuarios", fields: [contaId], references: [id], onDelete: Cascade)
  // Backrelation: contas onde este usuário é o owner
  ownedContas          Conta[]   @relation("ContaOwner")
  deletedContas        Conta[]   @relation("ContaDeletedBy")
  nome                 String
  email                String    @unique
  telefone             String?
  birthDate            DateTime?
  foto                 String?
  bio                  String?
  locale               String    @default("pt-BR")
  theme                String    @default("system")
  notifyEmailProduct   Boolean   @default(true)
  notifyEmailSecurity  Boolean   @default(true)
  notifyEmailMarketing Boolean   @default(false)
  notifyWhatsapp       Boolean   @default(true)
  notifySms            Boolean   @default(false)
  senhaHash            String
  emailVerifiedAt      DateTime?
  role                 Role      @default(RESPONSAVEL)
  status               Status    @default(ATIVO)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  colaborador           Colaborador?
  // Backrelation para vínculo opcional com Responsavel (1-1)
  responsavel           Responsavel?
  // Backrelation para vínculo opcional com Aluno (1-1)
  aluno                 Aluno?
  checkoutLinksCriados  CheckoutLink[]
  matriculaLogs         MatriculaLog[]
  logsFinanceiros       LogFinanceiro[]
  lancamentosCriados    Lancamento[]
  rematriculasOperacoes RematriculaOperacao[]
  payerChangeOperacoes  PayerChangeOperacao[]
  matriculaOperacoes    MatriculaOperacao[]
  notifications         NotificationRecipient[]
  attendanceRecorded    AttendanceRecord[]      @relation("AttendanceRecordedBy")
  makeupClassesCreated  MakeupClass[]           @relation("MakeupClassCreatedBy")
  authActionTokens      AuthActionToken[]
  salesOperated         Sale[]                  @relation("SalesOperated")
  inventoryMovementsCreated InventoryMovement[] @relation("InventoryMovementActor")
  restockOrdersCreated  RestockOrder[]          @relation("RestockOrderCreatedBy")
  acessosConta          UsuarioConta[]          @relation("UsuarioContaUsuario")
  acessosConvidados     UsuarioConta[]          @relation("UsuarioContaInvitedBy")

  @@index([contaId])
}

model UsuarioConta {
  id             String   @id @default(cuid())
  usuarioId      String
  contaId        String
  role           Role
  status         Status   @default(ATIVO)
  invitedById    String?
  inviteId       String?  @unique
  lastAccessedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  usuario   Usuario @relation("UsuarioContaUsuario", fields: [usuarioId], references: [id], onDelete: Cascade)
  conta     Conta   @relation(fields: [contaId], references: [id], onDelete: Cascade)
  invitedBy Usuario? @relation("UsuarioContaInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  invite    Invite? @relation("UsuarioContaInvite", fields: [inviteId], references: [id], onDelete: SetNull)

  @@unique([usuarioId, contaId])
  @@index([contaId, role, status], name: "idx_usuario_conta_conta_role_status")
  @@index([usuarioId, status], name: "idx_usuario_conta_usuario_status")
}

// --- Modelos de dom�nio Escola ---

model Aluno {
  id                             String    @id @default(cuid())
  contaId                        String
  nome                           String
  nomeSocial                     String?
  dataNasc                       DateTime
  cpf                            String?
  email                          String?
  telefone                       String?
  foto                           String?
  // Vinculação opcional com um usuário do sistema (para acesso/portal do aluno)
  usuarioId                      String?   @unique
  usuario                        Usuario?  @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  // Campos de endere�o estruturados
  enderecoCep                    String?   @db.Char(8)
  enderecoLogradouro             String?
  enderecoNumero                 String?
  enderecoComplemento            String?
  enderecoBairro                 String?
  enderecoCidade                 String?
  enderecoUf                     String?   @db.Char(2)
  observacao                     String?
  genero                         Genero?
  modalidadePrincipal            String?
  nivel                          String?
  alergias                       String?
  restricoesMedicas              String?
  contatoEmergenciaNome          String?
  contatoEmergenciaTelefone      String?
  origemCadastro                 String?
  bolsaDescontoPercent           Decimal?  @db.Decimal(5, 2)
  isentoTaxaMatricula            Boolean   @default(false)
  consentimentoImagem            Boolean   @default(false)
  dataConsentimentoImagem        DateTime?
  consentimentoComunicacoes      Boolean   @default(true)
  tamanhoCamiseta                String?
  tamanhoCalcado                 String?
  codigoInterno                  String?
  tags                           String[]  @default([])
  status                         Status    @default(ATIVO)
  asaasId                        String?   @unique
  asaasCustomerId                String?   @unique
  asaasCustomerExternalReference String?
  dataInativacao                 DateTime?
  motivoInativacao               String?
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt

  conta             Conta                   @relation(fields: [contaId], references: [id], onDelete: Cascade)
  inscricoesEvento  PortalEventoInscricao[]
  responsaveis      AlunoResponsavel[]
  matriculas        Matricula[]
  attendanceRecords AttendanceRecord[]
  makeupClasses     MakeupClass[]
  sales             Sale[]

  @@unique([contaId, cpf])
  @@unique([contaId, email])
  @@unique([contaId, codigoInterno])
  @@unique([contaId, asaasCustomerExternalReference])
  @@index([contaId])
}

model Responsavel {
  id                             String    @id @default(cuid())
  contaId                        String // Multi-tenant: cada responsável pertence a uma conta
  nome                           String
  cpf                            String
  email                          String
  telefone                       String
  // Campos de endereço estruturados
  enderecoCep                    String?
  enderecoLogradouro             String?
  enderecoNumero                 String?
  enderecoComplemento            String?
  enderecoBairro                 String?
  enderecoCidade                 String?
  enderecoUf                     String?
  financeiro                     Boolean   @default(false)
  asaasId                        String?
  asaasCustomerId                String?
  asaasCustomerExternalReference String?
  asaasCreditCardToken           String? // Token do cartão para débito automático
  // Metadados do cartão (para exibição, não contém dados sensíveis)
  creditCardBrand                String? // Bandeira do cartão (Visa, Mastercard, etc)
  creditCardLast4                String? // Últimos 4 dígitos
  creditCardExpiryMonth          Int? // Mês de expiração (1-12)
  creditCardExpiryYear           Int? // Ano de expiração (4 dígitos)
  creditCardUpdatedAt            DateTime? // Data da última atualização do cartão
  preferredBillingType           String? // Tipo de cobrança preferido (BOLETO, PIX, CREDIT_CARD)
  // Vinculação opcional com um usuário do sistema (para acesso via portal)
  usuarioId                      String?   @unique
  usuario                        Usuario?  @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  conta                 Conta              @relation(fields: [contaId], references: [id], onDelete: Cascade)
  alunos                AlunoResponsavel[]
  matriculasFinanceiras Matricula[]        @relation("MatriculaResponsavelFinanceiro")
  sales                 Sale[]

  // Multi-tenant: unicidade por conta
  @@unique([contaId, cpf])
  @@unique([contaId, email])
  @@unique([contaId, asaasCustomerExternalReference])
  @@index([contaId])
}

