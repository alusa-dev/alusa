model TransferRequest {
  id      String @id @default(cuid())
  contaId String

  value Decimal @db.Decimal(12, 2)

  // Snapshot do pedido (para auditoria/replay seguro)
  destination  Json
  description  String?
  scheduleDate DateTime?

  externalReference String  @unique
  asaasTransferId   String? @unique

  // Idempotência (ADR-009): suportar retries com a mesma chave
  idempotencyKey String

  status          TransferStatus @default(REQUESTED)
  statusUpdatedAt DateTime       @default(now())

  // Campos oficiais do Asaas — persistidos via webhook e GET confirmation
  rawAsaasStatus        String?
  authorized            Boolean?
  failReason            String?
  transactionReceiptUrl String?
  effectiveDate         String?
  endToEndIdentifier    String? // E2E único no Bacen (PIX)
  feeValue              Decimal? @db.Decimal(12, 2) // Taxa cobrada pelo Asaas (transferFee)
  netValue              Decimal? @db.Decimal(12, 2) // Valor líquido (value - transferFee)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conta              Conta               @relation(fields: [contaId], references: [id], onDelete: Restrict)
  pixTransferSession PixTransferSession?

  @@unique([contaId, idempotencyKey])
  @@index([contaId])
  @@index([status])
  @@index([asaasTransferId])
}

model PixTransferSession {
