// ==================== Rematrícula ====================

model RematriculaOperacao {
  id                String                    @id @default(cuid())
  correlationId     String                    @unique
  contaId           String
  matriculaOrigemId String
  matriculaNovaId   String?
  status            RematriculaOperacaoStatus @default(PENDING)
  step              RematriculaOperacaoStep   @default(VALIDATED)

  // Idempotência: permite retry seguro
  idempotencyKey String? @unique

  // IDs externos (provedor de pagamentos)
  oldSubscriptionId String?
  newSubscriptionId String?
  customerId        String?

  // Snapshot operacional da decisão
  policySnapshot       Json?
  financialSnapshot    Json?
  actionStatus         RematriculaActionStatus?
  blockReason          RematriculaBlockReason?  @default(SEM_BLOQUEIO)
  overrideUsed         Boolean                  @default(false)
  overrideReason       String?
  overrideApprovedById String?
  evaluatedAt          DateTime?
  blockedAt            DateTime?

  // Pagador (auditoria)
  payerType CustomerPayerType
  payerId   String

  // Erro (se houver)
  errorCode    String?
  errorMessage String?

  // Retry tracking
  retryCount  Int       @default(0)
  lastRetryAt DateTime?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conta           Conta      @relation(fields: [contaId], references: [id])
  matriculaOrigem Matricula  @relation("RematriculaOrigem", fields: [matriculaOrigemId], references: [id])
  matriculaNova   Matricula? @relation("RematriculaNova", fields: [matriculaNovaId], references: [id])
  createdBy       Usuario    @relation(fields: [createdById], references: [id])

  @@index([contaId])
  @@index([matriculaOrigemId])
  @@index([status])
  @@index([idempotencyKey])
}

// ==================== Troca de Pagador (PR4) ====================

model PayerChangeOperacao {
  id            String                    @id @default(cuid())
  correlationId String                    @unique
  contaId       String
  matriculaId   String
  status        PayerChangeOperacaoStatus @default(PENDING)

  // Pagador anterior
  oldPayerType      CustomerPayerType
  oldPayerId        String
  oldSubscriptionId String?

  // Novo pagador
  newPayerType      CustomerPayerType
  newPayerId        String
  newSubscriptionId String?
  newCustomerId     String?

  // Idempotência
  idempotencyKey String? @unique

  // Erro (se houver)
  errorCode    String?
  errorMessage String?

  // Retry tracking
  retryCount  Int       @default(0)
  lastRetryAt DateTime?

  // Auditoria
  reason      String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conta     Conta     @relation(fields: [contaId], references: [id])
  matricula Matricula @relation(fields: [matriculaId], references: [id])
  createdBy Usuario   @relation(fields: [createdById], references: [id])

  @@index([contaId])
  @@index([matriculaId])
  @@index([status])
}

