model Colaborador {
  id      String @id @default(cuid())
  contaId String

  // Identificação
  foto       String?
  nome       String
  nomeSocial String?
  dataNasc   DateTime?
  genero     Genero?

  // Documentos
  cpf          String?
  rg           String?
  orgaoEmissor String?
  dataEmissao  DateTime?

  // Contato
  email                     String?
  telefone1                 String?
  contatoEmergenciaTelefone String?

  // Endereço
  enderecoCep         String? @db.Char(8)
  enderecoLogradouro  String?
  enderecoNumero      String?
  enderecoComplemento String?
  enderecoBairro      String?
  enderecoCidade      String?
  enderecoUf          String? @db.Char(2)

  // Vínculo
  cargo            CargoColaborador
  especialidade    String?
  status           StatusColaborador @default(ATIVO)
  dataAdmissao     DateTime?
  dataDesligamento DateTime?
  observacoes      String?
  salario          Decimal?          @db.Decimal(12, 2)

  // Acesso ao sistema
  temAcesso Boolean  @default(false)
  usuarioId String?  @unique
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conta Conta @relation(fields: [contaId], references: [id], onDelete: Cascade)

  // Unicidade por conta (multi-tenant)
  @@unique([contaId, cpf])
  @@unique([contaId, email])
  @@index([contaId])
}

model Conta {
  // Tenant principal. Contas restauradas manualmente para recompor integridade
  // referencial devem manter o mesmo id e receber dados reais posteriormente.
  id                             String                           @id @default(cuid())
  nome                           String
  cpfCnpj                        String?
  status                         Status                           @default(ATIVO)
  financeStatus                  FinanceStatus                    @default(FINANCE_NOT_STARTED)
  financeIntegrationMode         FinanceIntegrationMode           @default(WHITELABEL_BAAS)
  externalAsaasOnboardingStatus  ExternalAsaasOnboardingStatus    @default(NOT_STARTED)
  deletedAt                      DateTime?
  deletedByUserId                String?
  deletedByUser                  Usuario?                         @relation("ContaDeletedBy", fields: [deletedByUserId], references: [id])
  deleteReason                   String?
  createdAt                      DateTime                         @default(now())
  updatedAt                      DateTime                         @updatedAt
  // Dono (owner) da conta — imutável na lógica de negócio
  ownerUserId                    String?
  ownerUser                      Usuario?                         @relation("ContaOwner", fields: [ownerUserId], references: [id])
  usuarios                       Usuario[]                        @relation("ContaUsuarios")
  usuariosConta                  UsuarioConta[]
  invites                        Invite[]
  alunos                         Aluno[]
  turmas                         Turma[]
  planos                         Plano[]
  combos                         Combo[]
  descontos                      Desconto[]
  webhooks                       WebhookAsaas[]
  webhooksArchive                WebhookAsaasArchive[]
  legalAcceptances               LegalAcceptance[]
  privacyRequests                PrivacyRequest[]
  sensitiveAccessLogs            SensitiveAccessLog[]
  consentRecords                 ConsentRecord[]
  financeReconciliationIssues    FinanceReconciliationIssue[]
  financeWebhookSideEffectOutbox FinanceWebhookSideEffectOutbox[]
  logsFinanceiros                LogFinanceiro[]
  logsIntegracao                 LogIntegracao[]
  asaasIntegrationJobs           AsaasIntegrationJob[]
  asaasNotificationPreferences   AsaasNotificationPreference[]
  // Núcleo financeiro whitelabel (Fases 0+)
  financeProfile                 FinanceProfile?
  tenantFeatureFlags             TenantFeatureFlags?
  auditLogs                      AuditLog[]
  notifications                  Notification[]
  notificationRecipients         NotificationRecipient[]
  customers                      Customer[]
  charges                        Charge[]
  chargeReadModels               ChargeReadModel[]
  financeSummaryReadModels       FinanceSummaryReadModel[]
  invoices                       Invoice[]
  subscriptions                  Subscription[]
  installmentPlans               InstallmentPlan[]
  standaloneInstallmentPlans     StandaloneInstallmentPlan[]
  standaloneSubscriptions        StandaloneSubscription[]
  transferRequests               TransferRequest[]
  pixTransferSessions            PixTransferSession[]
  professores                    Professor[]
  colaboradores                  Colaborador[]
  responsaveis                   Responsavel[]
  alunoResponsaveis              AlunoResponsavel[]
  modalidades                    Modalidade[]
  salas                          Sala[]
  matriculas                     Matricula[]
  cobrancas                      Cobranca[]
  pagamentos                     Pagamento[]
  turmaProfessores               TurmaProfessor[]
  matriculaTurmas                MatriculaTurma[]
  comboTurmas                    ComboTurma[]
  calendarEventProfessores       CalendarEventProfessor[]
  lancamentos                    Lancamento[]
  centrosCusto                   CentroCusto[]
  categoriasLancamento           CategoriaLancamento[]
  portalEventos                  PortalEvento[]
  portalEventoInscricoes         PortalEventoInscricao[]
  schoolEvents                   SchoolEvent[]
  eventMaps                      EventMap[]
  eventMapVersions               EventMapVersion[]
  eventMapLevels                 EventMapLevel[]
  eventMapObjects                EventMapObject[]
  eventMapSections               EventMapSection[]
  eventSeats                     EventSeat[]
  eventSeatGroups                EventSeatGroup[]
  eventMapPublicSeats            EventMapPublicSeat[]
  eventMapReservations           EventMapReservation[]
  eventMapReservationSeats       EventMapReservationSeat[]
  eventMapOrders                 EventMapOrder[]
  eventMapOrderItems             EventMapOrderItem[]
  eventTickets                   EventTicket[]
  eventTicketLots                EventTicketLot[]
  eventTicketSales               EventTicketSale[]
  eventCostumes                  EventCostume[]
  eventCostumeAssignments        EventCostumeAssignment[]
  eventFinancialEntries          EventFinancialEntry[]
  eventParticipants              EventParticipant[]
  eventReports                   EventReport[]
  eventAudits                    EventAudit[]
  contratoTemplates              ContratoTemplate[]
  contratoModelos                ContratoModelo[]
  rematriculaOperacoes           RematriculaOperacao[]
  payerChangeOperacoes           PayerChangeOperacao[]
  matriculaOperacoes             MatriculaOperacao[]
  matriculasFamiliares           MatriculaFamiliar[]
  rematriculasFamiliares         RematriculaFamiliar[]
  familyBillingOutboxEvents      FamilyBillingOutbox[]
  calendarEvents                 CalendarEvent[]
  aulasExperimentais             AulaExperimental[]
  attendanceRecords              AttendanceRecord[]
  makeupClasses                  MakeupClass[]
  aulasOperationLogs             AulasOperationLog[]
  // Loja / Vendas
  products                       Product[]
  productCategories              ProductCategory[]
  sales                          Sale[]
  inventoryBalances              InventoryBalance[]
  inventoryMovements             InventoryMovement[]
  restockOrders                  RestockOrder[]
  /// Fuso horário IANA para materialização da agenda (ex.: America/Sao_Paulo, America/Manaus)
  timezone                       String                           @default("America/Sao_Paulo") @db.VarChar(64)
  // Campos de endereço da conta (escola)
  enderecoCep                    String?                          @db.Char(8)
  enderecoLogradouro             String?
  enderecoNumero                 String?
  enderecoBairro                 String?
  enderecoCidade                 String?
  enderecoUf                     String?                          @db.Char(2)
  // Credenciais de integração (criptografadas em repouso). Armazenamos separadamente para permitir rotação.
  asaasApiKeyEncrypted           String?
  asaasWebhookSecretEncrypted    String?
  asaasCredsUpdatedAt            DateTime?
  // Política de ativação de matrícula
  matriculaActivationPolicy      MatriculaActivationPolicy        @default(IMMEDIATE)
  financialPolicy                ContaFinancialPolicy?

  @@index([cpfCnpj])
  @@index([ownerUserId])
  @@index([deletedAt])
  @@index([deletedByUserId])
  @@index([financeIntegrationMode])
  @@index([externalAsaasOnboardingStatus])
}

model ContaFinancialPolicy {
  id                                 String                @id @default(cuid())
  contaId                            String                @unique
  rematriculaDebtPolicy              RematriculaDebtPolicy @default(PERMITIR_NORMALMENTE)
  allowNewFinancialCycleWithOpenDebt Boolean               @default(true)
  debtScope                          RematriculaDebtScope  @default(QUALQUER_COBRANCA_EM_ABERTO)
  overrideRoles                      String[]              @default(["ADMIN", "FINANCEIRO"])
  requireOverrideReason              Boolean               @default(true)
  requireFullAudit                   Boolean               @default(true)
  blockOnUnknownFinancialStatus      Boolean               @default(true)
  createdAt                          DateTime              @default(now())
  updatedAt                          DateTime              @updatedAt

  conta Conta @relation(fields: [contaId], references: [id], onDelete: Cascade)

  @@index([contaId])
}

model AsaasNotificationPreference {
  id                              String                 @id @default(cuid())
  contaId                         String
  event                           AsaasNotificationEvent
  scheduleOffset                  Int                    @default(0)
  enabled                         Boolean                @default(true)
  emailEnabledForProvider         Boolean                @default(false)
  smsEnabledForProvider           Boolean                @default(false)
  emailEnabledForCustomer         Boolean                @default(true)
  smsEnabledForCustomer           Boolean                @default(true)
  whatsappEnabledForCustomer      Boolean                @default(false)
  phoneCallEnabledForCustomer     Boolean                @default(false)
  whatsappCapabilitySupported     Boolean                @default(true)
  whatsappCapabilityLastCheckedAt DateTime?
  whatsappCapabilityLastErrorCode String?
  whatsappCapabilityEnvironment   String?
  createdAt                       DateTime               @default(now())
  updatedAt                       DateTime               @updatedAt

  conta Conta @relation(fields: [contaId], references: [id], onDelete: Cascade)

  @@unique([contaId, event, scheduleOffset])
  @@index([contaId])
}

/// Modelo de Professor com foco em multi-tenant via contaId.
/// Decisões:
/// - status como String com default "ATIVO" (evita acoplamento a enum para flexibilidade futura).
/// - email opcional porém único globalmente (Postgres permite vários NULLs em índice único).
/// - nome terá validação de tamanho mínimo (>= 2) aplicada na camada de aplicação (Zod), não no schema.
/// - Relação futura com TurmaProfessor (campo `turmas`) ficará comentada até o modelo existir.
enum StatusContratual {
  EFETIVO
  TEMPORARIO
  PRESTADOR
  VOLUNTARIO
}

model Professor {
  id      String @id @default(cuid())
  contaId String

  // Dados pessoais
  nome          String
  cpf           String?
  rg            String?
  dataNasc      DateTime
  sexo          String?
  estadoCivil   String?
  nacionalidade String?

  // Contato
  email        String?
  telefoneCel  String
  telefoneFixo String?

  // Endereço
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  uf          String? @db.Char(2)

  // Profissional
  formacao         String?
  especialidades   String[]          @default([])
  dataAdmissao     DateTime?
  statusContratual StatusContratual?
  cargaHoraria     Int?
  miniBio          String?
  foto             String?

  status    Status   @default(ATIVO)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conta                    Conta                    @relation(fields: [contaId], references: [id], onDelete: Cascade)
  turmas                   TurmaProfessor[]
  calendarEventProfessores CalendarEventProfessor[]

  // Multi-tenant: unicidade por conta
  @@unique([contaId, cpf])
  @@unique([contaId, email])
  @@index([contaId], name: "idx_professor_conta")
  @@index([contaId, nome], name: "idx_professor_conta_nome")
  @@index([contaId, status], name: "idx_professor_conta_status")
}

model Usuario {
  id                   String    @id @default(cuid())
  // Conta padrão/legada do usuário. Para autorização multi-tenant, use UsuarioConta
  // e o activeContaId da sessão como fonte de verdade.
  contaId              String
  conta                Conta     @relation("ContaUsuarios", fields: [contaId], references: [id], onDelete: Cascade)
  // Backrelation: contas onde este usuário é o owner
  ownedContas          Conta[]   @relation("ContaOwner")
  deletedContas        Conta[]   @relation("ContaDeletedBy")
  nome                 String
  email                String    @unique
  telefone             String?
  birthDate            DateTime?
  foto                 String?
  bio                  String?
  locale               String    @default("pt-BR")
  theme                String    @default("system")
  notifyEmailProduct   Boolean   @default(true)
  notifyEmailSecurity  Boolean   @default(true)
  notifyEmailMarketing Boolean   @default(false)
  notifyWhatsapp       Boolean   @default(true)
  notifySms            Boolean   @default(false)
  welcomeWizardSeenAt  DateTime?
  senhaHash            String
  emailVerifiedAt      DateTime?
  role                 Role      @default(RESPONSAVEL)
  status               Status    @default(ATIVO)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  colaborador               Colaborador?
  // Backrelation para vínculo opcional com Responsavel (1-1)
  responsavel               Responsavel?
  // Backrelation para vínculo opcional com Aluno (1-1)
  aluno                     Aluno?
  checkoutLinksCriados      CheckoutLink[]
  matriculaLogs             MatriculaLog[]
  logsFinanceiros           LogFinanceiro[]
  lancamentosCriados        Lancamento[]
  rematriculasOperacoes     RematriculaOperacao[]
  payerChangeOperacoes      PayerChangeOperacao[]
  matriculaOperacoes        MatriculaOperacao[]
  notifications             NotificationRecipient[]
  attendanceRecorded        AttendanceRecord[]       @relation("AttendanceRecordedBy")
  makeupClassesCreated      MakeupClass[]            @relation("MakeupClassCreatedBy")
  authActionTokens          AuthActionToken[]
  legalAcceptances          LegalAcceptance[]
  cookieConsents            CookieConsent[]
  privacyRequests           PrivacyRequest[]
  sensitiveAccessLogs       SensitiveAccessLog[]
  consentRecords            ConsentRecord[]
  salesOperated             Sale[]                   @relation("SalesOperated")
  inventoryMovementsCreated InventoryMovement[]      @relation("InventoryMovementActor")
  restockOrdersCreated      RestockOrder[]           @relation("RestockOrderCreatedBy")
  schoolEventsResponsible   SchoolEvent[]            @relation("SchoolEventResponsibleUser")
  schoolEventsCreated       SchoolEvent[]            @relation("SchoolEventCreatedBy")
  eventMapVersionsPublished EventMapVersion[]        @relation("EventMapVersionPublishedBy")
  eventTicketSalesCreated   EventTicketSale[]        @relation("EventTicketSaleCreatedBy")
  eventAssignmentsDelivered EventCostumeAssignment[] @relation("EventCostumeAssignmentDeliveredBy")
  eventFinancialEntries     EventFinancialEntry[]    @relation("EventFinancialEntryCreatedBy")
  eventReportsGenerated     EventReport[]            @relation("EventReportGeneratedBy")
  eventAudits               EventAudit[]             @relation("EventAuditActor")
  acessosConta              UsuarioConta[]           @relation("UsuarioContaUsuario")
  acessosConvidados         UsuarioConta[]           @relation("UsuarioContaInvitedBy")

  @@index([contaId])
}

model UsuarioConta {
  id             String    @id @default(cuid())
  usuarioId      String
  contaId        String
  role           Role
  status         Status    @default(ATIVO)
  invitedById    String?
  inviteId       String?   @unique
  lastAccessedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Vínculo real de acesso multi-tenant. A autorização deve validar esta tabela
  // contra o activeContaId da sessão; Usuario.contaId não deve ser usado como autorização final.
  usuario   Usuario  @relation("UsuarioContaUsuario", fields: [usuarioId], references: [id], onDelete: Cascade)
  conta     Conta    @relation(fields: [contaId], references: [id], onDelete: Cascade)
  invitedBy Usuario? @relation("UsuarioContaInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  invite    Invite?  @relation("UsuarioContaInvite", fields: [inviteId], references: [id], onDelete: SetNull)

  @@unique([usuarioId, contaId])
  @@index([contaId, role, status], name: "idx_usuario_conta_conta_role_status")
  @@index([usuarioId, status], name: "idx_usuario_conta_usuario_status")
}

// --- Modelos de domínio Escola ---

model Aluno {
  id                             String    @id @default(cuid())
  contaId                        String
  nome                           String
  nomeSocial                     String?
  dataNasc                       DateTime
  cpf                            String?
  email                          String?
  telefone                       String?
  foto                           String?
  // Vinculação opcional com um usuário do sistema (para acesso/portal do aluno)
  usuarioId                      String?   @unique
  usuario                        Usuario?  @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  // Campos de endereço estruturados
  enderecoCep                    String?   @db.Char(8)
  enderecoLogradouro             String?
  enderecoNumero                 String?
  enderecoComplemento            String?
  enderecoBairro                 String?
  enderecoCidade                 String?
  enderecoUf                     String?   @db.Char(2)
  observacao                     String?
  genero                         Genero?
  modalidadePrincipal            String?
  nivel                          String?
  alergias                       String?
  restricoesMedicas              String?
  contatoEmergenciaNome          String?
  contatoEmergenciaTelefone      String?
  origemCadastro                 String?
  bolsaDescontoPercent           Decimal?  @db.Decimal(5, 2)
  isentoTaxaMatricula            Boolean   @default(false)
  consentimentoImagem            Boolean   @default(false)
  dataConsentimentoImagem        DateTime?
  consentimentoComunicacoes      Boolean   @default(true)
  tamanhoCamiseta                String?
  tamanhoCalcado                 String?
  codigoInterno                  String?
  tags                           String[]  @default([])
  status                         Status    @default(ATIVO)
  asaasId                        String?
  asaasCustomerId                String?
  asaasCustomerExternalReference String?
  dataInativacao                 DateTime?
  motivoInativacao               String?
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt

  conta              Conta                    @relation(fields: [contaId], references: [id], onDelete: Cascade)
  inscricoesEvento   PortalEventoInscricao[]
  responsaveis       AlunoResponsavel[]
  matriculas         Matricula[]
  aulasExperimentais AulaExperimental[]
  attendanceRecords  AttendanceRecord[]
  makeupClasses      MakeupClass[]
  sales              Sale[]
  eventTicketSales   EventTicketSale[]
  eventAssignments   EventCostumeAssignment[]
  eventParticipants  EventParticipant[]

  @@unique([contaId, cpf])
  @@unique([contaId, email])
  @@unique([contaId, codigoInterno])
  @@unique([contaId, asaasId])
  @@unique([contaId, asaasCustomerId])
  @@unique([contaId, asaasCustomerExternalReference])
  @@index([contaId])
  @@index([contaId, status], name: "idx_aluno_conta_status")
  @@index([contaId, createdAt], name: "idx_aluno_conta_created_at")
  @@index([contaId, nome], name: "idx_aluno_conta_nome")
  @@index([contaId, updatedAt], name: "idx_aluno_conta_updated_at")
}

model Responsavel {
  id                             String    @id @default(cuid())
  contaId                        String // Multi-tenant: cada responsável pertence a uma conta
  nome                           String
  cpf                            String
  email                          String
  telefone                       String
  foto                           String?
  // Campos de endereço estruturados
  enderecoCep                    String?
  enderecoLogradouro             String?
  enderecoNumero                 String?
  enderecoComplemento            String?
  enderecoBairro                 String?
  enderecoCidade                 String?
  enderecoUf                     String?
  financeiro                     Boolean   @default(false)
  asaasId                        String?
  asaasCustomerId                String?
  asaasCustomerExternalReference String?
  // Metadados do cartão (para exibição, não contém dados sensíveis)
  creditCardBrand                String? // Bandeira do cartão (Visa, Mastercard, etc)
  creditCardLast4                String? // Últimos 4 dígitos
  creditCardExpiryMonth          Int? // Mês de expiração (1-12)
  creditCardExpiryYear           Int? // Ano de expiração (4 dígitos)
  creditCardUpdatedAt            DateTime? // Data da última atualização do cartão
  preferredBillingType           String? // Tipo de cobrança preferido (BOLETO, PIX, CREDIT_CARD)
  // Vinculação opcional com um usuário do sistema (para acesso via portal)
  usuarioId                      String?   @unique
  usuario                        Usuario?  @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  conta                  Conta                 @relation(fields: [contaId], references: [id], onDelete: Cascade)
  alunos                 AlunoResponsavel[]
  matriculasFinanceiras  Matricula[]           @relation("MatriculaResponsavelFinanceiro")
  matriculasFamiliares   MatriculaFamiliar[]
  rematriculasFamiliares RematriculaFamiliar[]
  sales                  Sale[]
  eventTicketSales       EventTicketSale[]
  eventParticipants      EventParticipant[]

  // Multi-tenant: unicidade por conta
  @@unique([contaId, cpf])
  @@unique([contaId, email])
  @@unique([contaId, asaasId])
  @@unique([contaId, asaasCustomerExternalReference])
  @@index([contaId])
  @@index([contaId, nome], name: "idx_responsavel_conta_nome")
}

model AlunoResponsavel {
  id            String @id @default(cuid())
  contaId       String
  alunoId       String
  responsavelId String
  tipoVinculo   String

  conta       Conta       @relation(fields: [contaId], references: [id], onDelete: Restrict)
  aluno       Aluno       @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  responsavel Responsavel @relation(fields: [responsavelId], references: [id], onDelete: Cascade)

  @@unique([contaId, alunoId, responsavelId], name: "uq_aluno_responsavel_conta_aluno_responsavel", map: "uq_aluno_responsavel_conta_aluno_responsavel")
  @@index([contaId, alunoId], name: "idx_aluno_responsavel_conta_aluno")
  @@index([contaId, responsavelId], name: "idx_aluno_responsavel_conta_responsavel")
  @@index([alunoId])
  @@index([responsavelId])
}

model Turma {
  id           String   @id @default(cuid())
  contaId      String
  nome         String
  modalidadeId String
  salaId       String
  diasSemana   String[]
  horaInicio   String
  horaFim      String
  idadeMin     Int?
  idadeMax     Int?
  capacidade   Int
  status       String   @default("ATIVO")
  observacao   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  conta                Conta                    @relation(fields: [contaId], references: [id], onDelete: Cascade)
  modalidade           Modalidade               @relation(fields: [modalidadeId], references: [id])
  sala                 Sala                     @relation(fields: [salaId], references: [id])
  matriculas           Matricula[]
  combos               ComboTurma[]
  professores          TurmaProfessor[]
  matriculaTurmas      MatriculaTurma[]
  calendarEvents       CalendarEvent[]
  makeupClassesOrigem  MakeupClass[]            @relation("MakeupClassTurmaOrigem")
  makeupClassesDestino MakeupClass[]            @relation("MakeupClassTurmaDestino")
  eventAssignments     EventCostumeAssignment[]
  eventParticipants    EventParticipant[]

  @@unique([contaId, nome], name: "uq_turma_conta_nome")
  @@index([contaId], name: "idx_turma_conta")
  @@index([contaId, status], name: "idx_turma_conta_status")
  @@index([contaId, createdAt], name: "idx_turma_conta_created")
  @@index([contaId, updatedAt], name: "idx_turma_conta_updated")
  @@index([modalidadeId])
  @@index([salaId])
}

model Modalidade {
  id        String   @id @default(cuid())
  contaId   String
  nome      String
  descricao String?
  status    String   @default("ATIVO")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conta  Conta   @relation(fields: [contaId], references: [id], onDelete: Cascade)
  turmas Turma[]

  @@unique([contaId, nome], name: "uq_modalidade_conta_nome")
  @@index([contaId], name: "idx_modalidade_conta")
}

model Sala {
  id         String   @id @default(cuid())
  contaId    String
  nome       String
  descricao  String?
  capacidade Int
  status     Status   @default(ATIVO)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  conta          Conta           @relation(fields: [contaId], references: [id], onDelete: Cascade)
  turmas         Turma[]
  calendarEvents CalendarEvent[]

  @@unique([contaId, nome], name: "uq_sala_conta_nome")
  @@index([contaId], name: "idx_sala_conta")
}

model TurmaProfessor {
  id          String   @id @default(cuid())
  contaId     String
  turmaId     String
  professorId String
  createdAt   DateTime @default(now())

  conta     Conta     @relation(fields: [contaId], references: [id], onDelete: Restrict)
  turma     Turma     @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  professor Professor @relation(fields: [professorId], references: [id])

  @@unique([contaId, turmaId, professorId], name: "uq_turma_professor_conta_turma_professor", map: "uq_turma_professor_conta_turma_professor")
  @@unique([turmaId, professorId], name: "uq_turmaprofessor_unique")
  @@index([contaId, turmaId], name: "idx_turma_professor_conta_turma")
  @@index([contaId, professorId], name: "idx_turma_professor_conta_professor")
  @@index([turmaId], name: "idx_turmaprofessor_turma")
  @@index([professorId], name: "idx_turmaprofessor_professor")
}

model CalendarEvent {
  id               String              @id @default(cuid())
  contaId          String
  tipo             CalendarEventType
  status           CalendarEventStatus @default(AGENDADO)
  source           String?
  sourceRuleKey    String?
  manuallyAdjusted Boolean             @default(false)
  titulo           String
  descricao        String?
  startAt          DateTime
  endAt            DateTime
  turmaId          String?
  salaId           String?
  externalProvider String?
  externalEventId  String?
  syncedAt         DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  conta                Conta                    @relation(fields: [contaId], references: [id], onDelete: Cascade)
  turma                Turma?                   @relation(fields: [turmaId], references: [id], onDelete: SetNull)
  sala                 Sala?                    @relation(fields: [salaId], references: [id], onDelete: SetNull)
  professores          CalendarEventProfessor[]
  aulaExperimental     AulaExperimental?
  attendanceRecords    AttendanceRecord[]
  makeupClassesOrigem  MakeupClass[]            @relation("MakeupClassEventoOrigem")
  makeupClassesDestino MakeupClass[]            @relation("MakeupClassEventoDestino")

  @@unique([contaId, sourceRuleKey, startAt], name: "uq_calendar_event_source_rule_start")
  @@unique([contaId, externalProvider, externalEventId], name: "uq_calendar_event_external")
  @@index([contaId, startAt], name: "idx_calendar_event_conta_start")
  @@index([contaId, endAt], name: "idx_calendar_event_conta_end")
  @@index([contaId, startAt, endAt], name: "idx_calendar_event_conta_range")
  @@index([contaId, tipo, status], name: "idx_calendar_event_conta_tipo_status")
  @@index([contaId, tipo, startAt], name: "idx_calendar_event_conta_tipo_start")
  @@index([contaId, status, startAt], name: "idx_calendar_event_conta_status_start")
  @@index([contaId, turmaId, startAt], name: "idx_calendar_event_conta_turma_start")
  @@index([turmaId, startAt], name: "idx_calendar_event_turma_start")
  @@index([salaId, startAt], name: "idx_calendar_event_sala_start")
}

model CalendarEventProfessor {
  id              String   @id @default(cuid())
  contaId         String
  calendarEventId String
  professorId     String
  createdAt       DateTime @default(now())

  conta         Conta         @relation(fields: [contaId], references: [id], onDelete: Restrict)
  calendarEvent CalendarEvent @relation(fields: [calendarEventId], references: [id], onDelete: Cascade)
  professor     Professor     @relation(fields: [professorId], references: [id], onDelete: Cascade)

  @@unique([contaId, calendarEventId, professorId], name: "uq_calendar_event_professor_conta_event_professor", map: "uq_calendar_event_professor_conta_event_professor")
  @@unique([calendarEventId, professorId], name: "uq_calendar_event_professor")
  @@index([contaId, calendarEventId], name: "idx_calendar_event_professor_conta_event")
  @@index([contaId, professorId], name: "idx_calendar_event_professor_conta_professor")
  @@index([calendarEventId], name: "idx_calendar_event_professor_event")
  @@index([professorId], name: "idx_calendar_event_professor_professor")
}

model AttendanceRecord {
  id               String           @id @default(cuid())
  contaId          String
  calendarEventId  String
  alunoId          String
  matriculaId      String?
  status           AttendanceStatus
  observacao       String?
  recordedAt       DateTime
  recordedByUserId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  conta         Conta         @relation(fields: [contaId], references: [id], onDelete: Cascade)
  calendarEvent CalendarEvent @relation(fields: [calendarEventId], references: [id], onDelete: Cascade)
  aluno         Aluno         @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  matricula     Matricula?    @relation(fields: [matriculaId], references: [id], onDelete: SetNull)
  recordedBy    Usuario?      @relation("AttendanceRecordedBy", fields: [recordedByUserId], references: [id], onDelete: SetNull)

  @@unique([calendarEventId, alunoId], name: "uq_attendance_event_aluno")
  @@index([contaId, recordedAt], name: "idx_attendance_conta_recorded")
  @@index([contaId, alunoId, recordedAt], name: "idx_attendance_conta_aluno_recorded")
  @@index([contaId, calendarEventId], name: "idx_attendance_conta_event")
  @@index([contaId, status, recordedAt], name: "idx_attendance_conta_status_recorded")
  @@index([contaId, recordedByUserId, createdAt], name: "idx_attendance_conta_recorded_by_created")
  @@index([calendarEventId], name: "idx_attendance_event")
  @@index([alunoId], name: "idx_attendance_aluno")
  @@index([matriculaId], name: "idx_attendance_matricula")
}

model MakeupClass {
  id              String            @id @default(cuid())
  contaId         String
  scope           MakeupClassScope  @default(INDIVIDUAL)
  alunoId         String?
  matriculaId     String?
  eventoOrigemId  String
  eventoDestinoId String
  turmaOrigemId   String
  turmaDestinoId  String
  status          MakeupClassStatus @default(AGENDADA)
  observacao      String?
  createdByUserId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  conta         Conta         @relation(fields: [contaId], references: [id], onDelete: Cascade)
  aluno         Aluno?        @relation(fields: [alunoId], references: [id], onDelete: SetNull)
  matricula     Matricula?    @relation(fields: [matriculaId], references: [id], onDelete: SetNull)
  eventoOrigem  CalendarEvent @relation("MakeupClassEventoOrigem", fields: [eventoOrigemId], references: [id], onDelete: Cascade)
  eventoDestino CalendarEvent @relation("MakeupClassEventoDestino", fields: [eventoDestinoId], references: [id], onDelete: Cascade)
  turmaOrigem   Turma         @relation("MakeupClassTurmaOrigem", fields: [turmaOrigemId], references: [id], onDelete: Cascade)
  turmaDestino  Turma         @relation("MakeupClassTurmaDestino", fields: [turmaDestinoId], references: [id], onDelete: Cascade)
  createdBy     Usuario?      @relation("MakeupClassCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([contaId, createdAt], name: "idx_makeup_class_conta_created")
  @@index([contaId, alunoId], name: "idx_makeup_class_conta_aluno")
  @@index([contaId, status], name: "idx_makeup_class_conta_status")
  @@index([contaId, turmaOrigemId], name: "idx_makeup_class_conta_turma_origem")
  @@index([contaId, turmaDestinoId], name: "idx_makeup_class_conta_turma_destino")
  @@index([alunoId], name: "idx_makeup_class_aluno")
  @@index([matriculaId], name: "idx_makeup_class_matricula")
  @@index([eventoOrigemId], name: "idx_makeup_class_evento_origem")
  @@index([eventoDestinoId], name: "idx_makeup_class_evento_destino")
  @@index([turmaOrigemId], name: "idx_makeup_class_turma_origem")
  @@index([turmaDestinoId], name: "idx_makeup_class_turma_destino")
}

model AulaExperimental {
  id              String                 @id @default(cuid())
  contaId         String
  calendarEventId String                 @unique
  alunoId         String
  status          AulaExperimentalStatus @default(AGENDADA)
  observacao      String?
  uiRequestId     String?
  createdByUserId String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  conta         Conta         @relation(fields: [contaId], references: [id], onDelete: Cascade)
  calendarEvent CalendarEvent @relation(fields: [calendarEventId], references: [id], onDelete: Cascade)
  aluno         Aluno         @relation(fields: [alunoId], references: [id], onDelete: Restrict)

  @@unique([contaId, uiRequestId], name: "uq_aula_experimental_conta_request")
  @@index([contaId, status, createdAt], name: "idx_aula_experimental_conta_status_created")
  @@index([alunoId], name: "idx_aula_experimental_aluno")
}

model AulasOperationLog {
  id         String                 @id @default(cuid())
  contaId    String
  level      AulasOperationLogLevel @default(INFO)
  action     String
  entityType String?
  entityId   String?
  message    String
  details    Json?
  createdAt  DateTime               @default(now())

  conta Conta @relation(fields: [contaId], references: [id], onDelete: Cascade)

  @@index([contaId, createdAt], name: "idx_aulas_operation_log_conta_created")
  @@index([contaId, action], name: "idx_aulas_operation_log_conta_action")
  @@index([entityType, entityId], name: "idx_aulas_operation_log_entity")
}

model Plano {
  id            String             @id @default(cuid())
  contaId       String
  nome          String
  descricao     String?
  periodicidade PeriodicidadePlano @default(MENSAL)
  valor         Decimal            @db.Decimal(12, 2)
  status        Status             @default(ATIVO)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

