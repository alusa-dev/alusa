  @@index([contaId, status, createdAt], name: "idx_charge_read_model_conta_status_created")
  @@index([contaId, origin, status, createdAt], name: "idx_charge_read_model_conta_origin_status_created")
  @@index([contaId, chargeType, status, createdAt], name: "idx_charge_read_model_conta_type_status_created")
  @@index([contaId, origin, chargeType, isGroup, status, createdAt], name: "idx_charge_read_model_main_listing")
  @@index([contaId, payerName], name: "idx_charge_read_model_conta_payer")
