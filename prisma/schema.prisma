model Cobranca {
  id                String         @id @default(cuid())
  matriculaId       String
  tipo              TipoCobranca   @default(MENSALIDADE)
  descricao         String?
  competenciaInicio DateTime
  competenciaFim    DateTime
  valor             Decimal        @db.Decimal(12, 2)
  vencimento        DateTime
  dataPagamento     DateTime?
  formaPagamento    FormaPagamento @default(BOLETO)
  status            StatusCobranca @default(PENDENTE)
  asaasId           String?        @unique
  asaasPaymentId    String?        @unique

  // Campos financeiros adicionais - Juros
  jurosPercentual Decimal? @default(0) @db.Decimal(5, 2) // Percentual de juros ao mês (%)
  jurosValorFixo  Decimal? @default(0) @db.Decimal(12, 2) // Valor fixo de juros ao mês (R$)
  juros           Decimal? @default(0) @db.Decimal(12, 2) // Valor total de juros acumulados

  // Campos financeiros adicionais - Multa
  multaTipo       String?  @default("VALOR_FIXO") // VALOR_FIXO ou PERCENTUAL
  multaPercentual Decimal? @default(0) @db.Decimal(5, 2) // Percentual de multa (%)
  multaValorFixo  Decimal? @default(0) @db.Decimal(12, 2) // Valor fixo da multa (R$)
  multa           Decimal? @default(0) @db.Decimal(12, 2) // Valor total da multa aplicada

  // Campos financeiros adicionais - Desconto
  descontoTipo        String?  @default("VALOR_FIXO") // VALOR_FIXO ou PERCENTUAL
  descontoPercentual  Decimal? @default(0) @db.Decimal(5, 2) // Percentual de desconto (%)
  descontoValorFixo   Decimal? @default(0) @db.Decimal(12, 2) // Valor fixo do desconto (R$)
  descontoPrazoMaximo String?  @default("ATE_VENCIMENTO") // ATE_VENCIMENTO, 1_DIA, 3_DIAS, 7_DIAS, 15_DIAS, 30_DIAS
  desconto            Decimal? @default(0) @db.Decimal(12, 2) // Valor total do desconto aplicado

  valorFinal Decimal? @db.Decimal(12, 2) // Valor final com multa, juros e desconto aplicados

  // Campos de auditoria para rastreabilidade completa
  pagoEm          DateTime? // Data/hora em que o pagamento foi confirmado
  pagoPor         String? // Forma de pagamento real utilizada (pode diferir da esperada)
  canceladoEm     DateTime? // Data/hora do cancelamento
  canceladoMotivo String? // Motivo do cancelamento
  canceladoPor    String? // Usuário ou sistema que cancelou
  estornadoEm     DateTime? // Data/hora do estorno (total ou parcial)
  estornadoMotivo String? // Motivo do estorno
  estornadoValor  Decimal?  @db.Decimal(12, 2) // Valor estornado (para estornos parciais)
  estornadoPor    String? // Usuário ou sistema que estornou

  // ─────────────────────────────────────────────────────────────────────────────
  // Campos Asaas - Snapshot do estado remoto (NÃO alteram status/valor interno)
  // Populados via webhook ou reconciliação; GETs são read-only
  // ─────────────────────────────────────────────────────────────────────────────
  asaasStatus              String? // Snapshot do status Asaas (PENDING/CONFIRMED/RECEIVED/OVERDUE...)
  asaasValue               Decimal?  @db.Decimal(12, 2) // Valor bruto retornado pelo Asaas
  asaasNetValue            Decimal?  @db.Decimal(12, 2) // Valor líquido após taxa (netValue)
  asaasOriginalValue       Decimal?  @db.Decimal(12, 2) // Valor original se houve desconto antecipado
  asaasFeeValue            Decimal?  @db.Decimal(12, 2) // Taxa Asaas = asaasValue - asaasNetValue
  asaasCreditDate          DateTime? // Data em que o saldo foi/será creditado
  asaasEstimatedCreditDate DateTime? // Data estimada de crédito (antes de liquidar)
  lastAsaasFetchAt         DateTime? // Última busca no Asaas (throttle)
  lastAsaasFetchHash       String? // Hash do payload para evitar writes redundantes

  // Liquidação (saldo disponível) - sem alterar status interno
  liquidacaoStatus LiquidacaoStatus @default(NAO_APLICAVEL)
  liquidadoEm      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matricula            Matricula             @relation(fields: [matriculaId], references: [id], onDelete: Cascade)
  pagamentos           Pagamento[]
  logsFinanceiros      LogFinanceiro[]
  arquivos             ArquivoCobranca[]
  charge               Charge?
  asaasIntegrationJobs AsaasIntegrationJob[]

  @@index([matriculaId], name: "idx_cobranca_matricula")
  @@index([status], name: "idx_cobranca_status")
  @@index([tipo], name: "idx_cobranca_tipo")
  @@index([lastAsaasFetchAt], name: "idx_cobranca_last_asaas_fetch")
}

