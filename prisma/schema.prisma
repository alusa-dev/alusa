// --- Contratos Eletrônicos (PDF-based) ---

// Modelo de contrato: documento PDF reutilizável importado pela instituição
model ContratoModelo {
  id                 String   @id @default(cuid())
  contaId            String
  nome               String
  descricao          String?
  arquivoOriginalUrl String? // URL do arquivo original (DOCX se convertido)
  arquivoPdfUrl      String // URL do PDF final
  mimeType           String   @default("application/pdf")
  hashSha256         String // Hash SHA-256 para integridade
  tamanhoBytes       Int?
  versao             Int      @default(1)
  status             Status   @default(ATIVO)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  conta     Conta      @relation(fields: [contaId], references: [id], onDelete: Cascade)
  contratos Contrato[]

  @@unique([contaId, nome, versao], name: "uq_contrato_modelo_conta_nome_versao")
  @@index([contaId], name: "idx_contrato_modelo_conta")
  @@index([status], name: "idx_contrato_modelo_status")
}

// @deprecated - Mantido temporariamente para migração de dados
// TODO: Remover após migração completa dos templates antigos
model ContratoTemplate {
  id        String   @id @default(cuid())
  contaId   String
  nome      String
  conteudo  String   @db.Text // HTML com placeholders {{aluno.nome}}, etc
  versao    Int      @default(1)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conta Conta @relation(fields: [contaId], references: [id], onDelete: Cascade)

  @@unique([contaId, nome], name: "uq_contrato_template_conta_nome")
  @@index([contaId], name: "idx_contrato_template_conta")
}

model Contrato {
  id               String  @id @default(cuid())
  matriculaId      String
  modeloId         String? // Referência ao modelo de contrato usado
  contratoOrigemId String?

  // PDF final do contrato (imutável após assinatura)
  arquivoPdfUrl String // URL do PDF gerado para este aluno
  hashPdf       String // SHA-256 do PDF para prova de integridade

  // @deprecated - Campo legado para migração
  conteudoFinal String? @db.Text // HTML renderizado (contratos antigos)
  templateId    String? // Referência legada

  status StatusAssinatura @default(PENDENTE)

  // Dados da assinatura eletrônica
  assinadoPor       String? // Nome de quem assinou
  assinadoEmail     String? // Email
  assinadoCpf       String? // CPF (validado)
  assinadoIp        String? // IP da assinatura
  assinadoEm        DateTime? // Timestamp
  assinadoUserAgent String? // Navegador/device
  hashAssinatura    String? // SHA-256 do PDF + dados da assinatura

  // Link de compartilhamento
  tokenPublico  String    @unique @default(cuid())
  tokenExpiraEm DateTime? // Expiração do link (padrão: 7 dias)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matricula              Matricula         @relation("MatriculaContratos", fields: [matriculaId], references: [id], onDelete: Restrict)
  modelo                 ContratoModelo?   @relation(fields: [modeloId], references: [id])
  contratoOrigem         Contrato?         @relation("ContratoAditivo", fields: [contratoOrigemId], references: [id])
  aditivos               Contrato[]        @relation("ContratoAditivo")
  matriculaContratoAtual Matricula?        @relation("MatriculaContratoAtual")
  subscriptions          Subscription[]
  installmentPlans       InstallmentPlan[]

  @@index([matriculaId], name: "idx_contrato_matricula")
  @@index([modeloId], name: "idx_contrato_modelo")
  @@index([status], name: "idx_contrato_status")
  @@index([tokenPublico], name: "idx_contrato_token")
  @@index([tokenExpiraEm], name: "idx_contrato_token_expira")
  @@index([status, matriculaId], name: "idx_contrato_status_matricula")
}

// ==================== ASAAS WHITE LABEL (NOVO NÚCLEO) ====================

enum FinanceStatus {
  FINANCE_NOT_STARTED
  FINANCE_ONBOARDING_STARTED
  FINANCE_PROFILE_COMPLETED
  FINANCE_IN_ANALYSIS
  FINANCE_APPROVED
  FINANCE_REJECTED
}

enum FinancialOnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  READY_FOR_PROVISIONING
  PROVISIONING
  CREATED
  UNDER_REVIEW
  APPROVED
  REJECTED
  PROVISIONING_FAILED
}

enum KycProcessStatus {
  NOT_STARTED
  WAITING_MIN_TIMEOUT
  PENDING_DOCUMENTS
  EXTERNAL_IN_PROGRESS
  INTERNAL_UPLOADING
  UNDER_REVIEW
  REJECTED
  APPROVED
}

enum KycSubmissionMethod {
  EXTERNAL_ONBOARDING_URL
  INTERNAL_UPLOAD
}

enum KycDocumentStatus {
  NOT_SENT
  PENDING
  APPROVED
  REJECTED
  IGNORED
}

enum AsaasAccountDeletionState {
  NOT_REQUESTED
  DELETING
  DELETION_FAILED
  PENDING_EXTERNAL_DELETE
  DELETED_EXTERNALLY
  DELETED
}

enum AsaasCommercialInfoStatus {
  EXPIRING_SOON
  EXPIRED
}

enum AsaasApiKeyStatus {
  CONNECTED
  MISSING
  REVOKED
  INVALID
  EXPIRED
  DISABLED
  DELETED
}

enum AsaasWebhookStatus {
  NOT_CONFIGURED
  PENDING
  ACTIVE
  DRIFT
  INTERRUPTED
  INVALID_URL
  AUTH_TOKEN_MISMATCH
}

enum AsaasOperationalStatus {
  NOT_READY
  PROVISIONING
  API_KEY_REQUIRED
  WEBHOOK_REQUIRED
  KYC_PENDING
  UNDER_REVIEW
  OPERATIONAL
  BLOCKED
  REJECTED
}

enum FinanceProfileRegulatoryStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvoiceStatus {
  REQUESTED
  ISSUED
  CANCELING
  CANCELED
  ERROR
}

enum FinanceIntegrationMode {
  WHITELABEL_BAAS
  EXTERNAL_ASAAS_ACCOUNT
}

enum ExternalAsaasOnboardingStatus {
  NOT_STARTED
  PENDING_CONFIGURATION
  CONNECTING
  WEBHOOK_PENDING
  READY
  FAILED
}

enum AuditActorType {
  SYSTEM
  USER
  ADMIN
}

model FinanceProfile {
  id      String @id @default(cuid())
  contaId String @unique

  // Estado regulatório derivado do Asaas (/v3/myAccount/status)
  asaasAccountId        String?
  status                FinanceProfileRegulatoryStatus @default(PENDING)
  isOnboardingCompleted Boolean                        @default(false)
  onboardingCompletedAt DateTime?
  lastAsaasSyncAt       DateTime?

  // ================== Wizard Onboarding (draft antes de criar subconta) ==================
  // O wizard coleta dados em steps progressivos. Nenhuma chamada Asaas ocorre até primeira ação financeira.
  wizardStep        Int       @default(0) // 0=não iniciado, 1=tipo conta, 2=identificação, 3=contato, 4=endereço, 5=info financeira, 6=concluído
  wizardCompletedAt DateTime?
  draftPersonType   String? // 'PF' ou 'PJ'
  draftCpfCnpj      String? // CPF (11 dígitos) ou CNPJ (14 dígitos), apenas dígitos
  draftBirthDate    String? // YYYY-MM-DD (obrigatório para PF)

  // Dados mínimos para provisionar subconta (whitelabel.md)
  // Nome e dados opcionais do cadastro financeiro (não confundir com dados de perfil/conta do Alusa)
  asaasName        String? // legado
  asaasOwnerName   String?
  asaasCompanyName String?
  asaasLoginEmail  String?
  asaasPhone       String?
  asaasSite        String?

  mobilePhone   String?
  landlinePhone String?
  incomeValue   Decimal? @db.Decimal(12, 2)
  address       String?
  addressNumber String?
  province      String?
  addressCity   String?
  addressState  String?  @db.Char(2)
  postalCode    String?  @db.Char(8)
  complement    String?
  companyType   String? // MEI, LIMITED, INDIVIDUAL, ASSOCIATION (Necessário para PJ)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conta Conta @relation(fields: [contaId], references: [id], onDelete: Cascade)

  asaasAccount    AsaasAccount?
  asaasCredential AsaasCredential?

  @@index([contaId])
  @@index([asaasAccountId])
  @@index([status])
}

model AsaasAccount {
  id               String @id @default(cuid())
  financeProfileId String @unique

  // Pode começar como placeholder (antes da criação remota no Asaas)
  asaasAccountId    String? @unique
  externalReference String? @unique

  status          FinancialOnboardingStatus @default(NOT_STARTED)
  statusUpdatedAt DateTime                  @default(now())

  // Marca quando a subconta foi provisionada no Asaas (para respeitar delay recomendado antes de consultar /myAccount/documents)
  provisionedAt DateTime?

  // Observabilidade: tentativas de provisionamento
  provisionAttempts       Int       @default(0)
  provisionLastAttemptAt  DateTime?
  provisionLastError      String?
  provisionLastHttpStatus Int?

  // Status da confirmação anual de dados comerciais (webhooks COMMERCIAL_INFO_*).
  commercialInfoStatus        AsaasCommercialInfoStatus?
  commercialInfoScheduledDate String?

  // API key da subconta (criptografada). Usada para autenticação com /myAccount.
  apiKeyEncrypted String?
  apiKeyStatus    AsaasApiKeyStatus @default(MISSING)

  // Estado operacional local. CREATED significa apenas "subconta remota existe";
  // operationalStatus=OPERATIONAL é o que libera mutações financeiras externas.
  webhookStatus      AsaasWebhookStatus     @default(NOT_CONFIGURED)
  operationalStatus  AsaasOperationalStatus @default(NOT_READY)
  lastHealthCheckAt  DateTime?
  lastWebhookCheckAt DateTime?
  lastApiKeyCheckAt  DateTime?
  lastAsaasSyncAt    DateTime?
  provisionLockKey   String?
  provisionLastStage String?

  // Email principal da subconta no Asaas (usado como fallback em atualizações anuais).
  asaasAccountEmail String?

  // Cache best-effort da resposta do Asaas para /myAccount/documents
  documentsCache          Json?
  documentsCacheUpdatedAt DateTime?

  // Webhook (Fase 2): authToken configurado no Asaas (persistido como hash)
  webhookAuthTokenHash              String?   @unique
  previousWebhookAuthTokenHash      String?   @unique
  previousWebhookAuthTokenExpiresAt DateTime?

  // ==================== Delete Account (external-first) ====================
  deletionState          AsaasAccountDeletionState @default(NOT_REQUESTED)
  deletionRequestedAt    DateTime?
  deletionLastAttemptAt  DateTime?
  deletionAttempts       Int                       @default(0)
  deletionLastHttpStatus Int?
  deletionLastErrors     Json?
  deletedExternallyAt    DateTime?
  deletedLocallyAt       DateTime?
  deletedAsaasAccountId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  financeProfile FinanceProfile @relation(fields: [financeProfileId], references: [id], onDelete: Cascade)

  kycProcess KycProcess?

  statusHistory AsaasAccountStatusHistory[]

  @@index([financeProfileId])
  @@index([asaasAccountId])
  @@index([status])
  @@index([apiKeyStatus])
  @@index([webhookStatus])
  @@index([operationalStatus])
  @@index([deletionState])
  @@index([previousWebhookAuthTokenExpiresAt], name: "idx_asaas_account_prev_webhook_token_expires")
}

model AsaasAccountStatusHistory {
  id             String @id @default(cuid())
  asaasAccountId String

  oldStatus FinancialOnboardingStatus?
  newStatus FinancialOnboardingStatus

  event     String
  payloadId String?

  createdAt DateTime @default(now())

  asaasAccount AsaasAccount @relation(fields: [asaasAccountId], references: [id], onDelete: Cascade)

  @@index([asaasAccountId])
  @@index([newStatus])
  @@index([event])
}

model AsaasCredential {
  id               String @id @default(cuid())
  financeProfileId String @unique

  // API key da subconta (sempre criptografada em repouso)
  apiKeyEncrypted String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  financeProfile FinanceProfile @relation(fields: [financeProfileId], references: [id], onDelete: Cascade)

  @@index([financeProfileId])
}

model KycProcess {
  id String @id @default(cuid())

  asaasAccountId String @unique

  status                 KycProcessStatus @default(NOT_STARTED)
  rejectReasons          String[]
  nextAllowedDocsFetchAt DateTime?
  lastWebhookEventId     String?
  lastAsaasSyncAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  asaasAccount AsaasAccount     @relation(fields: [asaasAccountId], references: [id], onDelete: Cascade)
  requirements KycRequirement[]

  @@index([asaasAccountId])
  @@index([status])
}

model KycRequirement {
  id String @id @default(cuid())

  processId String
  groupId   String

  type        String?
  title       String?
  description String?

  submissionMethod KycSubmissionMethod
  status           KycDocumentStatus   @default(NOT_SENT)

  responsibleName String?
  responsibleType String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  process KycProcess @relation(fields: [processId], references: [id], onDelete: Cascade)
  slots   KycSlot[]

  @@unique([processId, groupId])
  @@index([processId])
  @@index([status])
}

model KycSlot {
  id String @id @default(cuid())

  requirementId String
  slotId        String

  status         KycDocumentStatus @default(NOT_SENT)
  uploadedFileId String?
  uiLabel        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requirement KycRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([requirementId, slotId])
  @@index([requirementId])
}

model Customer {
  id      String @id @default(cuid())
  contaId String

  payerType CustomerPayerType
  payerId   String

  externalReference String
  asaasCustomerId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conta                      Conta                       @relation(fields: [contaId], references: [id], onDelete: Cascade)
  charges                    Charge[]
  standaloneInstallmentPlans StandaloneInstallmentPlan[]
  standaloneSubscriptions    StandaloneSubscription[]

  @@unique([contaId, payerType, payerId])
  @@unique([contaId, asaasCustomerId])
  @@index([contaId])
  @@index([asaasCustomerId])
}

model Charge {
  id      String @id @default(cuid())
  contaId String

  cobrancaId String? @unique

  externalReference String @unique

  status          ChargeStatus @default(CREATED)
  statusUpdatedAt DateTime     @default(now())

  asaasPaymentId String? @unique

  // Campos para listagem de standalone charges (sem vínculo com Cobranca)
  // Preenchidos na criação para evitar consultas externas
  payerName     String? // Nome do pagador (aluno ou responsável)
  description   String? // Descrição da cobrança
  value         Decimal?  @db.Decimal(12, 2) // Valor da cobrança
  dueDate       DateTime? // Data de vencimento
  billingType   String? // PIX, BOLETO, CREDIT_CARD, etc.
  customerId    String? // ID do Customer local (para referência)
  invoiceUrl    String? // Link de pagamento (invoiceUrl do Asaas)
  familyGroupId String?

  standaloneInstallmentPlanId String?
  standaloneSubscriptionId    String?

  invoice Invoice?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conta                     Conta                      @relation(fields: [contaId], references: [id], onDelete: Restrict)
  cobranca                  Cobranca?                  @relation(fields: [cobrancaId], references: [id], onDelete: SetNull)
  customer                  Customer?                  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  standaloneInstallmentPlan StandaloneInstallmentPlan? @relation(fields: [standaloneInstallmentPlanId], references: [id], onDelete: SetNull)
  standaloneSubscription    StandaloneSubscription?    @relation(fields: [standaloneSubscriptionId], references: [id], onDelete: SetNull)
  arquivos                  ArquivoCharge[]
  asaasIntegrationJobs      AsaasIntegrationJob[]
  sale                      Sale?

  @@index([contaId])
  @@index([status])
  @@index([contaId, status, dueDate], name: "idx_charge_conta_status_due")
  @@index([contaId, standaloneInstallmentPlanId, dueDate], name: "idx_charge_conta_plan_due")
  @@index([contaId, createdAt], name: "idx_charge_conta_created")
  @@index([contaId, status, createdAt], name: "idx_charge_conta_status_created")
  @@index([contaId, asaasPaymentId], name: "idx_charge_conta_asaas_payment")
  @@index([asaasPaymentId])
  @@index([customerId])
  @@index([standaloneInstallmentPlanId])
  @@index([standaloneSubscriptionId])
  @@index([familyGroupId])
}

model ChargeReadModel {
