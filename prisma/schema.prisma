// --- Lançamentos financeiros ---
model Lancamento {
  id             String                    @id @default(cuid())
  contaId        String
  tipo           TipoLancamento
  origem         OrigemLancamento
  status         StatusLancamento
  valor          Decimal                   @db.Decimal(14, 2)
  descricao      String
  referencia     String?
  centroCustoId  String?
  categoriaId    String?
  subcategoriaId String?
  formaPagamento FormaPagamentoLancamento?
  dataEfetiva    DateTime?
  dataPrevista   DateTime?
  isEstorno      Boolean                   @default(false)
  parentId       String?
  dataEstorno    DateTime?
  motivoEstorno  String?
  observacao     String?
  anexoUrl       String?
  externalRef    String?
  createdById    String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  conta        Conta                @relation(fields: [contaId], references: [id], onDelete: Restrict)
