  @@index([contaId, status, nextRetryAt, recebidoEm], name: "idx_webhookasaas_tenant_queue")
  @@index([contaId, evento, recebidoEm], name: "idx_webhookasaas_conta_evento_recebido")
  @@index([contaId, recebidoEm], name: "idx_webhookasaas_conta_recebido")
  @@index([asaasPaymentId], name: "idx_webhookasaas_payment")
  @@index([asaasSubscriptionId], name: "idx_webhookasaas_subscription")
  @@index([asaasTransferId], name: "idx_webhookasaas_transfer")
  @@index([processadoEm], name: "idx_webhookasaas_processado")
  @@index([recebidoEm], name: "idx_webhookasaas_recebido_em")
}

