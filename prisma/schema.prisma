model Notification {
  id          String               @id @default(cuid())
  contaId     String
  type        NotificationType
  category    NotificationCategory
  severity    NotificationSeverity @default(INFO)
  title       String
  message     String
  dedupeKey   String
  relatedPath String?
  entityType  String?
  entityId    String?
  sourceType  String?
  sourceId    String?
  actorType   AuditActorType?
  actorId     String?
  metadata    Json?
  triggeredAt DateTime             @default(now())
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  conta      Conta                   @relation(fields: [contaId], references: [id], onDelete: Cascade)
  recipients NotificationRecipient[]

  @@unique([contaId, dedupeKey])
  @@index([contaId, triggeredAt])
  @@index([contaId, type, createdAt], name: "idx_notification_conta_type_created")
  @@index([contaId, category, createdAt], name: "idx_notification_conta_category_created")
  @@index([contaId, severity, createdAt], name: "idx_notification_conta_severity_created")
  @@index([contaId, sourceType, sourceId], name: "idx_notification_conta_source")
  @@index([contaId, entityType, entityId], name: "idx_notification_conta_entity")
  @@index([type])
  @@index([entityType, entityId])
}

model NotificationRecipient {
  id             String    @id @default(cuid())
  notificationId String
  contaId        String
  userId         String
  readAt         DateTime?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  conta        Conta        @relation(fields: [contaId], references: [id], onDelete: Cascade)
  user         Usuario      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([contaId, userId, archivedAt, readAt])
  @@index([contaId, userId, archivedAt, createdAt], name: "idx_notification_recipient_feed")
  @@index([contaId, userId, readAt], name: "idx_notification_recipient_read")
  @@index([userId, createdAt])
}

/// Fila de retry para notificações internas quando a entidade local ainda não existe.
model PendingInboxNotification {
  id          String                         @id @default(cuid())
  contaId     String?
  kind        String
  payload     Json
  dedupeKey   String                         @unique
  status      PendingInboxNotificationStatus @default(PENDING)
  attempts    Int                            @default(0)
  maxAttempts Int                            @default(5)
  nextRetryAt DateTime                       @default(now())
  lastError   String?
  createdAt   DateTime                       @default(now())
  processedAt DateTime?

  @@index([status, nextRetryAt])
  @@index([contaId, status, nextRetryAt])
}

// ==================== Rematrícula ====================

model RematriculaOperacao {
  id                String                    @id @default(cuid())
  correlationId     String                    @unique
  contaId           String
  matriculaOrigemId String
  matriculaNovaId   String?
  status            RematriculaOperacaoStatus @default(PENDING)
  step              RematriculaOperacaoStep   @default(VALIDATED)

  // Idempotência: permite retry seguro
  idempotencyKey String? @unique

  // IDs externos (provedor de pagamentos)
  oldSubscriptionId String?
  newSubscriptionId String?
  customerId        String?

  // Snapshot operacional da decisão
  policySnapshot       Json?
  financialSnapshot    Json?
  actionStatus         RematriculaActionStatus?
  blockReason          RematriculaBlockReason?  @default(SEM_BLOQUEIO)
  overrideUsed         Boolean                  @default(false)
  overrideReason       String?
  overrideApprovedById String?
  evaluatedAt          DateTime?
  blockedAt            DateTime?

  // Pagador (auditoria)
  payerType CustomerPayerType
  payerId   String

  // Erro (se houver)
  errorCode    String?
  errorMessage String?

  // Retry tracking
  retryCount  Int       @default(0)
  lastRetryAt DateTime?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conta           Conta      @relation(fields: [contaId], references: [id])
  matriculaOrigem Matricula  @relation("RematriculaOrigem", fields: [matriculaOrigemId], references: [id])
  matriculaNova   Matricula? @relation("RematriculaNova", fields: [matriculaNovaId], references: [id])
  createdBy       Usuario    @relation(fields: [createdById], references: [id])

  @@index([contaId])
  @@index([contaId, status], name: "idx_rematricula_operacao_conta_status")
  @@index([contaId, createdAt], name: "idx_rematricula_operacao_conta_created")
  @@index([contaId, matriculaOrigemId], name: "idx_rematricula_operacao_conta_matricula_origem")
  @@index([contaId, correlationId], name: "idx_rematricula_operacao_conta_correlation")
  @@index([matriculaOrigemId])
  @@index([status])
  @@index([idempotencyKey])
}

// ==================== Troca de Pagador (PR4) ====================

model PayerChangeOperacao {
  id            String                    @id @default(cuid())
  correlationId String                    @unique
  contaId       String
  matriculaId   String
  status        PayerChangeOperacaoStatus @default(PENDING)

  // Pagador anterior
  oldPayerType      CustomerPayerType
  oldPayerId        String
  oldSubscriptionId String?

  // Novo pagador
  newPayerType      CustomerPayerType
  newPayerId        String
  newSubscriptionId String?
  newCustomerId     String?

  // Idempotência
  idempotencyKey String? @unique

  // Erro (se houver)
  errorCode    String?
  errorMessage String?

  // Retry tracking
  retryCount  Int       @default(0)
  lastRetryAt DateTime?

  // Auditoria
  reason      String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  conta     Conta     @relation(fields: [contaId], references: [id])
  matricula Matricula @relation(fields: [matriculaId], references: [id])
  createdBy Usuario   @relation(fields: [createdById], references: [id])

  @@index([contaId])
  @@index([contaId, status], name: "idx_payer_change_operacao_conta_status")
  @@index([contaId, createdAt], name: "idx_payer_change_operacao_conta_created")
  @@index([contaId, matriculaId], name: "idx_payer_change_operacao_conta_matricula")
  @@index([contaId, correlationId], name: "idx_payer_change_operacao_conta_correlation")
  @@index([matriculaId])
  @@index([status])
}

// ─── Loja / Vendas ───

enum SaleStatus {
  CONCLUIDA
  PENDENTE
  VINCULADA_MENSALIDADE
  CANCELADA
}

enum SaleFinalizationType {
  RECEBIMENTO_PRESENCIAL
  COBRANCA
  MENSALIDADE
}

enum SalePaymentMethod {
  DINHEIRO
  PIX_PRESENCIAL
  CARTAO_DEBITO
  CARTAO_CREDITO
}

enum SaleInventoryMode {
  IMMEDIATE
  RESERVE
}

enum SaleInventoryStatus {
  FULFILLED
  RESERVED
  CANCELED
  RETURNED_PARTIAL
  RETURNED_TOTAL
}

enum InventoryMovementType {
  OPENING_IN
  ENTRY_IN
  RESTOCK_IN
  SALE_OUT
  RESERVE
  RELEASE
  RETURN_IN
  ADJUST_IN
  ADJUST_OUT
  LOSS_OUT
}

enum RestockOrderStatus {
  PLANEJADO
  RECEBIDO_PARCIAL
  RECEBIDO
  CANCELADO
}

model ProductCategory {
  id      String @id @default(cuid())
  contaId String
  name    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conta    Conta     @relation(fields: [contaId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([contaId, name])
  @@index([contaId])
}

model Product {
  id      String @id @default(cuid())
  contaId String

  name              String
  description       String?
  sku               String?
  price             Decimal @db.Decimal(12, 2)
  stock             Int     @default(0)
  lowStockThreshold Int     @default(5)
  categoryId        String?
  hasVariants       Boolean @default(false)

  isActive   Boolean   @default(true)
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conta              Conta               @relation(fields: [contaId], references: [id], onDelete: Cascade)
  category           ProductCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  saleItems          SaleItem[]
  images             ProductImage[]
  options            ProductOption[]
  variants           ProductVariant[]
  inventoryBalances  InventoryBalance[]
  inventoryMovements InventoryMovement[]
  restockOrderItems  RestockOrderItem[]

  @@unique([contaId, sku])
  @@index([contaId])
  @@index([contaId, archivedAt])
  @@index([contaId, isActive], name: "idx_product_conta_active")
  @@index([contaId, categoryId], name: "idx_product_conta_category")
  @@index([contaId, name], name: "idx_product_conta_name")
  @@index([contaId, createdAt], name: "idx_product_conta_created")
}

model Sale {
  id          String  @id @default(cuid())
  contaId     String
  uiRequestId String?

  saleNumber Int
  status     SaleStatus @default(PENDENTE)

  // Cliente
  customerType  String // 'ALUNO' | 'RESPONSAVEL' | 'AVULSO'
  alunoId       String?
  responsavelId String?
  walkInName    String?
  walkInPhone   String?
  walkInNotes   String?

  // Valores
  subtotal    Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  totalCost   Decimal? @db.Decimal(12, 2)
  grossProfit Decimal? @db.Decimal(12, 2)
  grossMargin Decimal? @db.Decimal(9, 4)

  // Finalização
  finalizationType SaleFinalizationType
  inventoryMode    SaleInventoryMode    @default(IMMEDIATE)
  inventoryStatus  SaleInventoryStatus  @default(FULFILLED)

  // Recebimento presencial
  paymentMethod  SalePaymentMethod?
  amountReceived Decimal?           @db.Decimal(12, 2)
  changeGiven    Decimal?           @db.Decimal(12, 2)

  // Vínculo financeiro
  chargeId                    String? @unique
  standaloneInstallmentPlanId String?
  matriculaId                 String?

  // Operador
  operadorId String

  // Cancelamento
  canceledAt   DateTime?
  cancelReason String?
  canceledById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conta                     Conta                      @relation(fields: [contaId], references: [id], onDelete: Cascade)
  aluno                     Aluno?                     @relation(fields: [alunoId], references: [id], onDelete: SetNull)
  responsavel               Responsavel?               @relation(fields: [responsavelId], references: [id], onDelete: SetNull)
  charge                    Charge?                    @relation(fields: [chargeId], references: [id], onDelete: SetNull)
  standaloneInstallmentPlan StandaloneInstallmentPlan? @relation(fields: [standaloneInstallmentPlanId], references: [id], onDelete: SetNull)
  matricula                 Matricula?                 @relation(fields: [matriculaId], references: [id], onDelete: SetNull)
  operador                  Usuario                    @relation("SalesOperated", fields: [operadorId], references: [id], onDelete: Restrict)
  items                     SaleItem[]

  @@unique([contaId, uiRequestId])
  @@unique([contaId, saleNumber])
  @@index([contaId])
  @@index([contaId, status])
  @@index([contaId, createdAt])
  @@index([contaId, alunoId], name: "idx_sale_conta_aluno")
  @@index([contaId, responsavelId], name: "idx_sale_conta_responsavel")
  @@index([contaId, operadorId], name: "idx_sale_conta_operador")
  @@index([chargeId])
  @@index([standaloneInstallmentPlanId])
  @@index([saleNumber, contaId])
}

model SaleItem {
  id     String @id @default(cuid())
  saleId String

  productId           String?
  variantId           String?
  productName         String
  quantity            Int
  returnedQuantity    Int      @default(0)
  unitPrice           Decimal  @db.Decimal(12, 2)
  subtotal            Decimal  @db.Decimal(12, 2)
  unitCostAtSale      Decimal? @db.Decimal(12, 4)
  totalCostAtSale     Decimal? @db.Decimal(12, 2)
  discountShareAtSale Decimal? @db.Decimal(12, 2)
  netSubtotalAtSale   Decimal? @db.Decimal(12, 2)
  grossProfitAtSale   Decimal? @db.Decimal(12, 2)
  marginAtSale        Decimal? @db.Decimal(9, 4)

  createdAt DateTime @default(now())

  sale    Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([saleId])
  @@index([productId])
  @@index([variantId])
}

model InventoryBalance {
  id               String   @id @default(cuid())
  contaId          String
  inventoryItemKey String
  productId        String
  variantId        String?
  onHand           Int      @default(0)
  reserved         Int      @default(0)
  incoming         Int      @default(0)
  averageCost      Decimal  @default(0) @db.Decimal(12, 4)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  conta   Conta           @relation(fields: [contaId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([contaId, inventoryItemKey])
  @@unique([variantId])
  @@index([contaId])
  @@index([contaId, productId], name: "idx_inventory_balance_conta_product")
  @@index([contaId, variantId], name: "idx_inventory_balance_conta_variant")
  @@index([productId])
  @@index([variantId])
}

model InventoryMovement {
  id               String                @id @default(cuid())
  contaId          String
  inventoryItemKey String
  productId        String
  variantId        String?
  movementType     InventoryMovementType
  onHandBefore     Int
  onHandDelta      Int
  onHandAfter      Int
  reservedBefore   Int
  reservedDelta    Int
  reservedAfter    Int
  incomingBefore   Int
  incomingDelta    Int
  incomingAfter    Int
  unitCost         Decimal?              @db.Decimal(12, 4)
  totalCost        Decimal?              @db.Decimal(14, 4)
  originType       String
  originId         String
  originLineId     String                @default("ROOT")
  originActionKey  String
  actorUserId      String?
  reason           String?
  createdAt        DateTime              @default(now())

  conta   Conta           @relation(fields: [contaId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  actor   Usuario?        @relation("InventoryMovementActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@unique([contaId, originType, originId, originLineId, originActionKey, movementType])
  @@index([contaId])
  @@index([contaId, productId, createdAt], name: "idx_inventory_movement_conta_product_created")
  @@index([contaId, variantId, createdAt], name: "idx_inventory_movement_conta_variant_created")
  @@index([contaId, movementType, createdAt], name: "idx_inventory_movement_conta_type_created")
  @@index([contaId, actorUserId, createdAt], name: "idx_inventory_movement_conta_actor_created")
  @@index([productId])
  @@index([variantId])
  @@index([createdAt])
  @@index([movementType])
}

model RestockOrder {
  id             String             @id @default(cuid())
  contaId        String
  status         RestockOrderStatus @default(PLANEJADO)
  supplierName   String?
  expectedAt     DateTime?
  notes          String?
  createdById    String
  canceledAt     DateTime?
  canceledReason String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  conta     Conta              @relation(fields: [contaId], references: [id], onDelete: Cascade)
  createdBy Usuario            @relation("RestockOrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  items     RestockOrderItem[]

  @@index([contaId])
  @@index([contaId, status])
  @@index([contaId, expectedAt], name: "idx_restock_order_conta_expected")
  @@index([contaId, createdById], name: "idx_restock_order_conta_created_by")
  @@index([expectedAt])
}

model RestockOrderItem {
  id                String   @id @default(cuid())
  restockOrderId    String
  productId         String
  variantId         String?
  quantityExpected  Int
  quantityReceived  Int      @default(0)
  estimatedUnitCost Decimal? @db.Decimal(12, 4)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  restockOrder RestockOrder    @relation(fields: [restockOrderId], references: [id], onDelete: Cascade)
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([restockOrderId])
  @@index([productId])
  @@index([variantId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductOption {
  id        String @id @default(cuid())
  productId String
  name      String
  sortOrder Int    @default(0)

  product Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values  ProductOptionValue[]

  @@unique([productId, name])
  @@index([productId])
}

model ProductOptionValue {
  id        String @id @default(cuid())
  optionId  String
  value     String
  sortOrder Int    @default(0)

  option   ProductOption          @relation(fields: [optionId], references: [id], onDelete: Cascade)
  variants ProductVariantOption[]

  @@unique([optionId, value])
  @@index([optionId])
}

model ProductVariant {
  id                String   @id @default(cuid())
  productId         String
  title             String
  sku               String?
  price             Decimal? @db.Decimal(12, 2)
  stock             Int      @default(0)
  lowStockThreshold Int      @default(5)
  imageUrl          String?
  isDefault         Boolean  @default(false)
  sortOrder         Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product            Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  options            ProductVariantOption[]
  saleItems          SaleItem[]
  inventoryBalances  InventoryBalance[]
  inventoryMovements InventoryMovement[]
  restockOrderItems  RestockOrderItem[]

  @@unique([productId, sku])
  @@index([productId])
}

model ProductVariantOption {
  variantId     String
  optionValueId String

  variant     ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@id([variantId, optionValueId])
}
