  conta       Conta        @relation(fields: [contaId], references: [id], onDelete: Cascade)
  event       SchoolEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  aluno       Aluno?       @relation(fields: [alunoId], references: [id], onDelete: SetNull)
  turma       Turma?       @relation(fields: [turmaId], references: [id], onDelete: SetNull)
  responsavel Responsavel? @relation(fields: [responsavelId], references: [id], onDelete: SetNull)

  @@index([contaId], name: "idx_event_participant_conta")
  @@index([contaId, eventId, type], name: "idx_event_participant_conta_event_type")
  @@index([contaId, alunoId], name: "idx_event_participant_conta_aluno")
  @@index([contaId, turmaId], name: "idx_event_participant_conta_turma")
  @@index([contaId, responsavelId], name: "idx_event_participant_conta_responsavel")
}

