model Invite {
  id               String    @id @default(cuid())
  // A conta do convidador no momento da criação do convite (usada no aceite)
  contaId          String?
  email            String? // Opcional para convites de RESPONSAVEL
  role             Role
  token            String    @unique
  invitedById      String
  status           String    @default("PENDING")
  expiresAt        DateTime
  // Auditoria de aceite
  acceptedByUserId String?
  acceptedAt       DateTime?
  metadata         Json? // Armazena dados extras como alunosIds para RESPONSAVEL
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relação opcional para garantir integridade sem quebrar convites antigos
  conta        Conta?        @relation(fields: [contaId], references: [id], onDelete: Cascade)
  usuarioConta UsuarioConta? @relation("UsuarioContaInvite")

  @@index([email, status], name: "idx_invite_email_status")
  @@index([expiresAt], name: "idx_invite_expires")
  @@index([contaId], name: "idx_invite_conta")
}

