model Matricula {
  id                      String                @id @default(cuid())
  alunoId                 String
  responsavelFinanceiroId String?
  turmaId                 String?
  planoId                 String? // Opcional quando comboId é fornecido (combo define valor/periodicidade)
  comboId                 String?
  rematriculadaDeId       String? // Referência à matrícula origem (rematrícula)
  dataInicio              DateTime
  dataFim                 DateTime?
  dataFimContrato         DateTime
  status                  StatusMatricula       @default(ATIVA)
  statusFinanceiro        StatusFinanceiro      @default(PENDENTE_TAXA)
  statusContrato          StatusContrato        @default(AGUARDANDO_ASSINATURA)
  contratoAtualId         String?               @unique
  taxaMatricula           Decimal               @db.Decimal(12, 2)
  taxaStatus              StatusTaxaMatricula   @default(PENDENTE)
  taxaIsenta              Boolean               @default(false)
  taxaJustificativa       String?
  formaPagamento          FormaPagamento?       @default(BOLETO)
  formaPagamentoTaxa      FormaPagamento?       @default(BOLETO)
  vencimentoDia           Int                   @default(5)
  // Configurações financeiras de juros, multa e desconto (padrão Asaas API)
  // @see https://docs.asaas.com/docs/criando-uma-assinatura
  jurosMensal             Decimal?              @db.Decimal(5, 2) // Ex: 1.0 = 1% ao mês
  jurosTipo               String?               @default("PERCENTAGE") // FIXED ou PERCENTAGE (Asaas)
  multaPercentual         Decimal?              @db.Decimal(5, 2) // Ex: 2.0 = 2%
  multaTipo               String?               @default("PERCENTAGE") // FIXED ou PERCENTAGE (Asaas)
  descontoAntecipado      Decimal?              @db.Decimal(5, 2) // Ex: 5.0 = 5% de desconto
  descontoTipo            String?               @default("PERCENTAGE") // FIXED ou PERCENTAGE (Asaas)
  prazoDesconto           Int?                  @default(0) // Quantos dias antes do vencimento para aplicar desconto
  asaasId                 String?               @unique
  asaasSubscriptionId     String?               @unique
  billingMode             BillingMode           @default(INDIVIDUAL) // Modo de cobrança (PR2)
  timeoutAppliedAt        DateTime? // Quando timeout foi aplicado (PR3)
  // Campos de pausa
  pausaAtiva              Boolean               @default(false)
  dataInicioPausa         DateTime?
  dataRetornoPrevista     DateTime?
  manterVaga              Boolean               @default(true)
  cobrarDurantePausa      Boolean               @default(false)
  motivoPausa             String?
  integrationStatus       IntegrationSyncStatus @default(SINCRONIZADO)
  warningCode             String?
  version                 Int                   @default(0)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  aluno                      Aluno                 @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  responsavelFinanceiro      Responsavel?          @relation("MatriculaResponsavelFinanceiro", fields: [responsavelFinanceiroId], references: [id])
  turma                      Turma?                @relation(fields: [turmaId], references: [id])
  plano                      Plano?                @relation(fields: [planoId], references: [id])
  combo                      Combo?                @relation(fields: [comboId], references: [id])
  descontos                  DescontoMatricula[]
  cobrancas                  Cobranca[]
  checkoutLinks              CheckoutLink[]
  logs                       MatriculaLog[]
  matriculaTurmas            MatriculaTurma[]
  contratos                  Contrato[]            @relation("MatriculaContratos")
  contratoAtual              Contrato?             @relation("MatriculaContratoAtual", fields: [contratoAtualId], references: [id])
  subscriptions              Subscription[]
  installmentPlans           InstallmentPlan[]
  operacoes                  MatriculaOperacao[]
  rematriculadaDe            Matricula?            @relation("RematriculaHistorico", fields: [rematriculadaDeId], references: [id])
  rematriculasDerivadas      Matricula[]           @relation("RematriculaHistorico")
  rematriculaOperacoesOrigem RematriculaOperacao[] @relation("RematriculaOrigem")
  rematriculaOperacoesNova   RematriculaOperacao[] @relation("RematriculaNova")
  payerChangeOperacoes       PayerChangeOperacao[]
  attendanceRecords          AttendanceRecord[]
  makeupClasses              MakeupClass[]
  sales                      Sale[]

  @@index([alunoId], name: "idx_matricula_aluno")
  @@index([responsavelFinanceiroId], name: "idx_matricula_responsavel")
  @@index([turmaId], name: "idx_matricula_turma")
  @@index([planoId], name: "idx_matricula_plano")
  @@index([comboId], name: "idx_matricula_combo")
  @@index([status], name: "idx_matricula_status")
  @@index([statusContrato], name: "idx_matricula_status_contrato")
  @@index([dataFimContrato], name: "idx_matricula_fim_contrato")
  @@index([contratoAtualId], name: "idx_matricula_contrato_atual")
}

