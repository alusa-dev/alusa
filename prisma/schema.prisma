  @@index([contaId, entityType, entityId], name: "idx_event_audit_conta_entity")
  @@index([contaId, action, createdAt], name: "idx_event_audit_conta_action")
  @@index([contaId, actorUserId, createdAt], name: "idx_event_audit_conta_actor")
